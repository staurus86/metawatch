<%
  function reportsLabel(planName) {
    const key = String(planName || '').toLowerCase();
    if (key === 'free') return 'Portfolio PDF/CSV + URL/Uptime PDF (30d)';
    if (key === 'starter') return 'All PDF/XLSX/CSV + Project reports (90d)';
    if (key === 'pro') return 'All PDF/XLSX/CSV + Project reports (365d)';
    if (key === 'agency') return 'All reports + white-label + unlimited range';
    return '—';
  }
%>

<div class="page-header">
  <div>
    <h1 class="page-title">Billing & Plan</h1>
    <div class="text-muted" style="font-size:13px;margin-top:4px">
      Current plan limits, usage and upgrade options.
    </div>
  </div>
  <div style="display:flex;gap:8px;align-items:center">
    <a href="/reports" class="btn btn-ghost">Reports Center</a>
    <a href="/export/report.pdf" class="btn btn-ghost">Download PDF Report</a>
    <a href="/dashboard" class="btn btn-ghost">← Dashboard</a>
  </div>
</div>

<% if (billingError) { %>
  <div class="alert-banner alert-banner--error" style="margin-bottom:14px"><%= billingError %></div>
<% } %>
<% if (billingMessage) { %>
  <div class="alert-banner alert-banner--ok" style="margin-bottom:14px"><%= billingMessage %></div>
<% } %>
<% if (!stripeEnabled) { %>
  <div class="alert-banner alert-banner--info" style="margin-bottom:14px">
    Stripe is not configured yet. Set Stripe ENV variables to enable online upgrades.
  </div>
<% } %>

<div class="card" style="margin-bottom:18px">
  <div class="card-header">
    <h2 class="card-title">Current Plan</h2>
    <span class="badge badge--ok"><%= plan.name %></span>
  </div>
  <div style="padding:16px">
    <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
      <div class="text-muted" style="font-size:13px">
        Status:
        <strong><%= subscription?.status || 'active' %></strong>
      </div>
      <% if (trialEndsAt) { %>
        <div class="badge badge--changed">
          Trial ends: <%= new Date(trialEndsAt).toISOString().slice(0, 10) %>
        </div>
      <% } %>
      <div class="text-muted" style="font-size:13px">
        Min check interval: <strong><%= plan.check_interval_min %> min</strong>
      </div>
    </div>
  </div>
</div>

<div class="card" style="margin-bottom:18px">
  <div class="card-header">
    <h2 class="card-title">Usage</h2>
  </div>
  <div style="padding:16px;display:grid;gap:14px">
    <% usageRows.forEach(function(row) { %>
      <div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;font-size:13px">
          <span><%= row.label %></span>
          <div style="display:flex;gap:8px;align-items:center">
            <strong><%= row.used %>/<%= row.limit == null ? '∞' : row.limit %></strong>
            <% if (row.limit != null && row.used >= row.limit) { %>
              <a href="/billing?upgrade=1" class="btn btn-ghost" style="font-size:11px;padding:3px 8px">Upgrade</a>
            <% } %>
          </div>
        </div>
        <div style="height:10px;border-radius:999px;background:var(--bg-secondary);border:1px solid var(--border);overflow:hidden">
          <div style="height:100%;width:<%= row.percent == null ? 8 : row.percent %>%;background:<%= row.percent == null ? 'var(--accent)' : row.percent >= 90 ? 'var(--error)' : row.percent >= 70 ? 'var(--changed)' : 'var(--ok)' %>"></div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2 class="card-title">Plan Comparison</h2>
  </div>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>Plan</th>
          <th>Price</th>
          <th>URLs</th>
          <th>Uptime Monitors</th>
          <th>Projects</th>
          <th>Reports</th>
          <th>Min Interval</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% plans.forEach(function(p) { %>
          <tr>
            <td><strong><%= p.name %></strong></td>
            <td><%= Number(p.price_usd || 0) === 0 ? '$0' : ('$' + p.price_usd + '/mo') %></td>
            <td><%= limitLabel(p.max_urls) %></td>
            <td><%= limitLabel(p.max_uptime_monitors) %></td>
            <td><%= limitLabel(p.max_projects) %></td>
            <td><%= reportsLabel(p.name) %></td>
            <td><%= p.check_interval_min %> min</td>
            <td>
              <% if (String(p.name).toLowerCase() === String(plan.name).toLowerCase()) { %>
                <span class="badge badge--ok">Current</span>
              <% } else if (Number(p.price_usd || 0) <= 0) { %>
                <span class="badge badge--pending">Included</span>
              <% } else if (checkoutEnabledByPlan && checkoutEnabledByPlan[p.name]) { %>
                <form action="/billing/checkout" method="POST" style="display:inline">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <input type="hidden" name="plan" value="<%= p.name %>">
                  <button type="submit" class="btn btn-ghost" style="font-size:12px;padding:4px 10px">
                    Upgrade
                  </button>
                </form>
              <% } else { %>
                <span class="badge badge--paused">Unavailable</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% if (requestedUpgrade && !billingError) { %>
  <div class="alert-banner alert-banner--info" style="margin:14px">
      Requested upgrade target: <strong><%= requestedUpgrade %></strong>
  </div>
<% } %>
</div>
