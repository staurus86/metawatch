<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <span class="logo-icon">👁</span>
      <span class="logo-text">MetaWatch</span>
    </div>
    <h1 class="auth-title"><%= title %></h1>

    <% if (typeof isFirstUser !== 'undefined' && isFirstUser) { %>
      <div class="alert-banner alert-banner--info">
        You are creating the first account — it will have <strong>admin</strong> access.
      </div>
    <% } %>

    <% if (error) { %>
      <div class="alert-banner alert-banner--error"><%= error %></div>
    <% } %>

    <form action="<%= inviteToken ? '/invite/' + inviteToken : '/register' %>" method="POST" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="form-group">
        <label class="form-label" for="email">Email</label>
        <input type="email" id="email" name="email" class="form-input"
               value="<%= email || '' %>"
               placeholder="you@example.com" required
               <%= typeof inviteToken !== 'undefined' && inviteToken ? 'readonly' : '' %>>
      </div>
      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="form-input"
               placeholder="At least 8 characters" required minlength="8">
      </div>
      <div class="form-group">
        <label class="form-label" for="password2">Confirm Password</label>
        <input type="password" id="password2" name="password2" class="form-input"
               placeholder="Repeat password" required minlength="8">
      </div>
      <button type="submit" class="btn btn-primary btn-full">
        <%= typeof inviteToken !== 'undefined' && inviteToken ? 'Accept Invitation' : 'Create Account' %>
      </button>
    </form>

    <div class="auth-footer">
      Already have an account? <a href="/login">Sign in</a>
    </div>
  </div>
</div>
