<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> — Status</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f0f4f8; color: #2d3748; }
    .container { max-width: 860px; margin: 0 auto; padding: 32px 16px 60px; }
    .header { text-align: center; margin-bottom: 36px; }
    .header h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; }
    .header p { color: #718096; font-size: 15px; }
    .overall { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 16px 24px; border-radius: 12px; margin-bottom: 28px; font-size: 18px; font-weight: 700; }
    .overall--up { background: #f0fff4; color: #276749; border: 1px solid #9ae6b4; }
    .overall--down { background: #fff5f5; color: #9b2c2c; border: 1px solid #fed7d7; }
    .overall--degraded { background: #fffaf0; color: #7b341e; border: 1px solid #fbd38d; }
    .card { background: white; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.08); margin-bottom: 20px; overflow: hidden; }
    .card-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #718096; padding: 14px 20px 10px; border-bottom: 1px solid #e2e8f0; }
    .monitor-row { display: flex; align-items: center; padding: 14px 20px; border-bottom: 1px solid #f0f4f8; gap: 12px; }
    .monitor-row:last-child { border-bottom: none; }
    .status-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
    .dot-up { background: #48bb78; }
    .dot-down { background: #e53e3e; }
    .dot-degraded { background: #ed8936; }
    .dot-unknown { background: #a0aec0; }
    .monitor-name { font-weight: 600; font-size: 15px; flex: 1; }
    .monitor-url { font-size: 12px; color: #718096; word-break: break-all; }
    .monitor-meta { text-align: right; font-size: 12px; color: #718096; flex-shrink: 0; }
    .badge { display: inline-flex; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
    .badge-up { background: #f0fff4; color: #276749; border: 1px solid #9ae6b4; }
    .badge-down { background: #fff5f5; color: #9b2c2c; border: 1px solid #fed7d7; }
    .badge-degraded { background: #fffaf0; color: #7b341e; border: 1px solid #fbd38d; }
    .incident-row { padding: 12px 20px; border-bottom: 1px solid #f0f4f8; font-size: 13px; }
    .incident-row:last-child { border-bottom: none; }
    .subscribe-section { text-align: center; padding: 28px; }
    .subscribe-section input[type=email] { padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 14px; width: 260px; margin-right: 8px; }
    .subscribe-section button { background: #4299e1; color: white; border: none; padding: 10px 18px; border-radius: 6px; font-size: 14px; cursor: pointer; }
    .footer { text-align: center; margin-top: 40px; font-size: 12px; color: #a0aec0; }
    .alert-banner { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; text-align: center; font-size: 14px; }
    .alert-ok { background: #f0fff4; color: #276749; border: 1px solid #9ae6b4; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1><%= page.title %></h1>
      <% if (page.description) { %><p><%= page.description %></p><% } %>
    </div>

    <% if (message) { %><div class="alert-banner alert-ok"><%= message %></div><% } %>
    <% if (subscribed) { %><div class="alert-banner alert-ok">✓ Check your email to confirm your subscription.</div><% } %>

    <!-- Overall status -->
    <div class="overall overall--<%= overallStatus %>">
      <span><%= overallStatus === 'up' ? '✅' : overallStatus === 'degraded' ? '⚠️' : '🔴' %></span>
      <span><%= overallStatus === 'up' ? 'All Systems Operational' : overallStatus === 'degraded' ? 'Partial Degradation' : 'Service Disruption' %></span>
    </div>

    <!-- Active incidents -->
    <% if (activeIncidents && activeIncidents.length > 0) { %>
    <div class="card">
      <div class="card-title">🔴 Active Incidents (<%= activeIncidents.length %>)</div>
      <% activeIncidents.forEach(function(inc) { %>
        <div class="incident-row">
          <strong><%= inc.monitor_name %></strong> — <%= inc.cause || 'Service disruption' %>
          <span style="color:#718096;font-size:11px;margin-left:8px">Started <%= new Date(inc.started_at).toUTCString().replace(' GMT','') %></span>
          <% if (inc.postmortem_text) { %>
            <div style="margin-top:6px;font-size:12px;color:#4a5568"><%= inc.postmortem_text %></div>
          <% } %>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Monitors -->
    <div class="card">
      <div class="card-title">Monitors</div>
      <% monitors.forEach(function(m) { %>
        <div class="monitor-row">
          <span class="status-dot dot-<%= m.last_status || 'unknown' %>"></span>
          <div style="flex:1">
            <div class="monitor-name"><%= m.name %></div>
            <div class="monitor-url"><%= m.url %></div>
          </div>
          <div class="monitor-meta">
            <span class="badge badge-<%= m.last_status || 'unknown' %>"><%= (m.last_status || 'unknown').toUpperCase() %></span>
            <% if (m.last_rt != null) { %><div style="margin-top:4px"><%= m.last_rt %>ms</div><% } %>
            <% if (m.uptime_pct != null) { %><div style="margin-top:2px"><%= m.uptime_pct %>% uptime (24h)</div><% } %>
          </div>
        </div>
      <% }) %>
      <% if (monitors.length === 0) { %>
        <div style="padding:24px;text-align:center;color:#718096">No monitors on this page.</div>
      <% } %>
    </div>

    <!-- Recent incidents -->
    <% if (recentIncidents && recentIncidents.length > 0) { %>
    <div class="card">
      <div class="card-title">Recent Incidents</div>
      <% recentIncidents.forEach(function(inc) { %>
        <div class="incident-row">
          <div>
            <strong><%= inc.monitor_name %></strong> —
            <span style="color:<%= inc.resolved_at ? '#38a169' : '#e53e3e' %>">
              <%= inc.resolved_at ? 'Resolved' : 'Ongoing' %>
            </span>
            <% if (inc.resolved_at && inc.duration_seconds) { %>
              <span style="color:#718096;font-size:11px"> (downtime: <%= fmtDuration(inc.duration_seconds) %>)</span>
            <% } %>
            <% if (inc.cause) { %><code style="font-size:11px;color:#718096;margin-left:6px"><%= inc.cause %></code><% } %>
          </div>
          <div style="font-size:11px;color:#718096;margin-top:3px"><%= new Date(inc.started_at).toUTCString().replace(' GMT','') %></div>
          <% if (inc.postmortem_text) { %>
            <div style="margin-top:6px;font-size:12px;padding:8px;background:#f7fafc;border-radius:4px"><%= inc.postmortem_text %></div>
          <% } %>
        </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Subscribe -->
    <div class="card">
      <div class="subscribe-section">
        <div style="font-size:15px;font-weight:600;margin-bottom:10px">Get Status Updates</div>
        <div style="font-size:13px;color:#718096;margin-bottom:16px"><%= subscriberCount %> subscriber<%= subscriberCount !== 1 ? 's' : '' %></div>
        <form action="/status/page/<%= page.slug %>/subscribe" method="POST">
          <input type="email" name="email" placeholder="your@email.com" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="footer">Powered by <strong>MetaWatch</strong></div>
  </div>
</body>
</html>
