<!DOCTYPE html>
<html lang="<%= lang || 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> — Status</title>
  <style>
    :root {
      --brand: <%= (page.primary_color || '#4299e1') %>;
      --ink: #10223a;
      --muted: #5f7290;
      --panel: #ffffff;
      --line: #dbe5f4;
      --up: #16a34a;
      --down: #dc2626;
      --degraded: #d97706;
      --unknown: #64748b;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "Segoe UI Variable", "Trebuchet MS", "Lucida Sans Unicode", sans-serif;
      color: var(--ink);
      min-height: 100vh;
      background:
        radial-gradient(circle at 10% -8%, rgba(37, 99, 235, 0.2), transparent 38%),
        radial-gradient(circle at 95% 0%, rgba(14, 165, 233, 0.18), transparent 42%),
        linear-gradient(180deg, #f8fbff 0%, #eff5ff 78%);
    }

    .container { max-width: 1040px; margin: 0 auto; padding: 24px 16px 58px; }

    .reveal { animation: reveal .55s ease both; }
    .reveal:nth-of-type(2) { animation-delay: .05s; }
    .reveal:nth-of-type(3) { animation-delay: .1s; }
    .reveal:nth-of-type(4) { animation-delay: .15s; }

    @keyframes reveal {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero {
      border: 1px solid var(--line);
      border-radius: 16px;
      background: linear-gradient(145deg, #ffffff 0%, #f7fbff 100%);
      box-shadow: 0 10px 28px rgba(30, 58, 138, 0.08);
      padding: 22px;
      display: grid;
      grid-template-columns: 1.15fr .85fr;
      gap: 14px;
      align-items: center;
    }

    .hero-eyebrow {
      color: var(--brand);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .09em;
      font-weight: 700;
      margin-bottom: 8px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .hero-eyebrow::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: var(--brand);
      box-shadow: 0 0 0 5px rgba(66, 153, 225, 0.22);
      animation: pulse 2s ease infinite;
    }

    @keyframes pulse {
      0% { transform: scale(1); opacity: 1; }
      70% { transform: scale(1.28); opacity: .45; }
      100% { transform: scale(1); opacity: 1; }
    }

    .logo-wrap { margin-bottom: 12px; }
    .logo-wrap img { max-height: 48px; max-width: 220px; object-fit: contain; }

    .hero h1 {
      margin: 0;
      font-size: clamp(24px, 4vw, 38px);
      letter-spacing: -0.03em;
      line-height: 1.05;
    }

    .hero p {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .hero-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 14px;
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 999px;
      padding: 7px 13px;
      font-size: 12px;
      font-weight: 700;
      color: #2d4e77;
    }

    .hero-status-dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      display: inline-block;
    }

    .dot-up { background: var(--up); }
    .dot-down { background: var(--down); }
    .dot-degraded { background: var(--degraded); }
    .dot-unknown { background: var(--unknown); }

    .hero-right {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .score {
      --ring: 0deg;
      width: 164px;
      height: 164px;
      border-radius: 999px;
      background: conic-gradient(var(--brand) var(--ring), #d9e4f5 0deg);
      display: grid;
      place-items: center;
      position: relative;
    }

    .score::after {
      content: "";
      width: 126px;
      height: 126px;
      border-radius: 999px;
      background: #fff;
      border: 1px solid var(--line);
      position: absolute;
    }

    .score-inner {
      position: relative;
      z-index: 1;
      text-align: center;
      font-size: 26px;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .score-inner small {
      display: block;
      margin-top: 6px;
      text-transform: uppercase;
      letter-spacing: .07em;
      font-size: 10px;
      font-weight: 700;
      color: var(--muted);
    }

    .alert-banner {
      border-radius: 10px;
      padding: 10px 14px;
      margin: 12px 0 0;
      font-size: 14px;
      border: 1px solid #9ee7db;
      color: #0f766e;
      background: #ecfdf8;
      text-align: center;
    }

    .card {
      margin-top: 14px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--panel);
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
      overflow: hidden;
    }

    .card-title {
      padding: 12px 14px;
      border-bottom: 1px solid var(--line);
      text-transform: uppercase;
      letter-spacing: .07em;
      font-size: 11px;
      color: var(--muted);
      font-weight: 700;
      background: linear-gradient(180deg, #fcfdff 0%, #f7faff 100%);
    }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
      padding: 14px;
    }

    .summary-cell {
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #f8fbff;
      padding: 10px;
      text-align: center;
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .05em;
      font-weight: 700;
    }

    .summary-cell b {
      display: block;
      margin-top: 4px;
      color: var(--ink);
      font-size: 21px;
      letter-spacing: -0.02em;
      text-transform: none;
    }

    .summary-cell--up b { color: #15803d; }
    .summary-cell--degraded b { color: #a16207; }
    .summary-cell--down b { color: #b91c1c; }

    .monitor-grid {
      padding: 14px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .monitor-card {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #f9fcff;
      padding: 12px;
    }

    .monitor-head {
      display: flex;
      gap: 8px;
      align-items: flex-start;
    }

    .monitor-name { font-size: 15px; font-weight: 700; }
    .monitor-url {
      margin-top: 3px;
      font-size: 12px;
      color: var(--muted);
      word-break: break-all;
      line-height: 1.45;
    }

    .badge {
      margin-left: auto;
      border-radius: 999px;
      padding: 3px 9px;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .05em;
      border: 1px solid transparent;
      font-weight: 700;
      line-height: 1.2;
      min-width: 74px;
      text-align: center;
    }

    .badge-up { color: #166534; background: #ecfdf5; border-color: #86efac; }
    .badge-down { color: #991b1b; background: #fef2f2; border-color: #fecaca; }
    .badge-degraded { color: #92400e; background: #fffbeb; border-color: #fcd34d; }
    .badge-unknown { color: #334155; background: #f1f5f9; border-color: #cbd5e1; }

    .monitor-meta {
      margin-top: 10px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px;
      font-size: 12px;
      color: #36557c;
    }

    .monitor-meta div {
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 8px;
      padding: 6px 8px;
      text-align: center;
    }

    .timeline { padding: 8px 14px 14px; }

    .incident-row {
      border-left: 3px solid #d6e3f6;
      margin-top: 8px;
      padding: 8px 10px 8px 12px;
      background: #fbfdff;
      border-radius: 0 10px 10px 0;
    }

    .incident-row--active { border-left-color: #f87171; background: #fff8f8; }

    .incident-title {
      font-size: 13px;
      font-weight: 700;
      color: #1f3a5d;
      line-height: 1.45;
    }

    .incident-meta {
      margin-top: 4px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.45;
    }

    .postmortem {
      margin-top: 6px;
      font-size: 12px;
      color: #415f85;
      border: 1px dashed #cbd8eb;
      border-radius: 8px;
      background: #f6faff;
      padding: 6px 8px;
      line-height: 1.45;
      white-space: pre-wrap;
    }

    .subscribe-section {
      padding: 24px 18px;
      text-align: center;
    }

    .subscribe-title {
      font-size: 18px;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 6px;
    }

    .subscribe-sub {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .subscribe-form {
      display: flex;
      justify-content: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .subscribe-form input[type=email] {
      width: min(300px, 92vw);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 14px;
      outline: none;
      background: #fff;
    }

    .subscribe-form input[type=email]:focus {
      border-color: var(--brand);
      box-shadow: 0 0 0 3px rgba(66, 153, 225, 0.2);
    }

    .subscribe-form button {
      border: none;
      border-radius: 10px;
      padding: 10px 16px;
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      background: linear-gradient(180deg, var(--brand), #1e3a8a);
      cursor: pointer;
    }

    .subscribe-form button:hover { filter: brightness(1.04); }

    .footer {
      margin-top: 22px;
      text-align: center;
      font-size: 12px;
      color: var(--muted);
    }

    .footer a {
      color: var(--brand);
      text-decoration: none;
      font-weight: 700;
    }

    .footer a:hover { text-decoration: underline; }

    @media (max-width: 930px) {
      .hero { grid-template-columns: 1fr; }
      .summary-grid { grid-template-columns: repeat(3, 1fr); }
      .monitor-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 620px) {
      .container { padding: 16px 10px 42px; }
      .hero { padding: 16px; border-radius: 14px; }
      .summary-grid { grid-template-columns: repeat(2, 1fr); }
      .score { width: 136px; height: 136px; }
      .score::after { width: 104px; height: 104px; }
      .score-inner { font-size: 22px; }
      .summary-cell { padding: 8px; }
      .summary-cell b { font-size: 18px; }
    }
  </style>
</head>
<body>
  <%
    const totalMonitors = monitors.length;
    const upCount = monitors.filter(m => m.last_status === 'up').length;
    const degradedCount = monitors.filter(m => m.last_status === 'degraded').length;
    const downCount = monitors.filter(m => m.last_status === 'down').length;
    const unknownCount = Math.max(0, totalMonitors - upCount - degradedCount - downCount);
    const total24h = Number(summary?.total_checks_24h || 0);
    const ok24h = Number(summary?.ok_checks_24h || 0);
    const availability24h = total24h > 0 ? Math.round((ok24h / total24h) * 1000) / 10 : null;
    const scoreDeg = availability24h == null ? 0 : Math.max(0, Math.min(100, availability24h)) * 3.6;
    const overallLabel = overallStatus === 'up'
      ? 'All Systems Operational'
      : overallStatus === 'degraded'
        ? 'Partial Degradation'
        : 'Service Disruption';
    const overallDot = overallStatus === 'up'
      ? 'dot-up'
      : overallStatus === 'degraded'
        ? 'dot-degraded'
        : 'dot-down';
  %>

  <div class="container">
    <header class="hero reveal">
      <div>
        <% if (page.logo_url) { %>
          <div class="logo-wrap">
            <img src="<%= page.logo_url %>" alt="<%= page.title %> logo">
          </div>
        <% } %>

        <div class="hero-eyebrow">Public Status Report</div>
        <h1><%= page.title %></h1>
        <% if (page.description) { %><p><%= page.description %></p><% } %>

        <div class="hero-status">
          <span class="hero-status-dot <%= overallDot %>"></span>
          <span><%= overallLabel %></span>
        </div>
      </div>

      <div class="hero-right">
        <div class="score" style="--ring:<%= scoreDeg %>deg">
          <div class="score-inner"><%= availability24h == null ? '—' : (availability24h + '%') %><small>Healthy checks 24h</small></div>
        </div>
      </div>
    </header>

    <% if (message) { %><div class="alert-banner reveal"><%= message %></div><% } %>
    <% if (subscribed) { %><div class="alert-banner reveal">Check your email to confirm your subscription.</div><% } %>

    <section class="card reveal">
      <div class="card-title">Network Summary (24h)</div>
      <div class="summary-grid">
        <div class="summary-cell"><span>Monitors</span><b><%= totalMonitors %></b></div>
        <div class="summary-cell summary-cell--up"><span>Up</span><b><%= upCount %></b></div>
        <div class="summary-cell summary-cell--degraded"><span>Degraded</span><b><%= degradedCount %></b></div>
        <div class="summary-cell summary-cell--down"><span>Down</span><b><%= downCount %></b></div>
        <div class="summary-cell"><span>Unknown</span><b><%= unknownCount %></b></div>
      </div>
    </section>

    <% if (activeIncidents && activeIncidents.length > 0) { %>
      <section class="card reveal">
        <div class="card-title">Active Incidents (<%= activeIncidents.length %>)</div>
        <div class="timeline">
          <% activeIncidents.forEach(function(inc) { %>
            <article class="incident-row incident-row--active">
              <div class="incident-title"><%= inc.monitor_name %> — <%= inc.cause || 'Service disruption' %></div>
              <div class="incident-meta">Started <%= new Date(inc.started_at).toUTCString().replace(' GMT','') %></div>
              <% if (inc.postmortem_text) { %><div class="postmortem"><%= inc.postmortem_text %></div><% } %>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>

    <section class="card reveal">
      <div class="card-title">Live Monitors</div>
      <% if (monitors.length === 0) { %>
        <div class="timeline"><article class="incident-row"><div class="incident-title">No monitors on this page.</div></article></div>
      <% } else { %>
        <div class="monitor-grid">
          <% monitors.forEach(function(m) { %>
            <% const badgeClass = m.last_status === 'up' ? 'badge-up' : m.last_status === 'degraded' ? 'badge-degraded' : m.last_status === 'down' ? 'badge-down' : 'badge-unknown'; %>
            <% const dotClass = m.last_status === 'up' ? 'dot-up' : m.last_status === 'degraded' ? 'dot-degraded' : m.last_status === 'down' ? 'dot-down' : 'dot-unknown'; %>
            <article class="monitor-card">
              <div class="monitor-head">
                <span class="hero-status-dot <%= dotClass %>"></span>
                <div style="flex:1">
                  <div class="monitor-name"><%= m.name %></div>
                  <div class="monitor-url"><%= m.url %></div>
                </div>
                <span class="badge <%= badgeClass %>"><%= (m.last_status || 'unknown').toUpperCase() %></span>
              </div>

              <div class="monitor-meta">
                <div>Last RT: <strong><%= m.last_rt != null ? (m.last_rt + 'ms') : '—' %></strong></div>
                <div>Avg 24h: <strong><%= m.avg_rt_24h != null ? (m.avg_rt_24h + 'ms') : '—' %></strong></div>
                <div>Uptime 24h: <strong><%= m.uptime_24h != null ? (m.uptime_24h + '%') : '—' %></strong></div>
                <div>Uptime 7d: <strong><%= m.uptime_7d != null ? (m.uptime_7d + '%') : '—' %></strong></div>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <% if (recentIncidents && recentIncidents.length > 0) { %>
      <section class="card reveal">
        <div class="card-title">Recent Incidents</div>
        <div class="timeline">
          <% recentIncidents.forEach(function(inc) { %>
            <article class="incident-row">
              <div class="incident-title"><%= inc.monitor_name %> — <%= inc.resolved_at ? 'Resolved' : 'Ongoing' %></div>
              <div class="incident-meta">
                <%= new Date(inc.started_at).toUTCString().replace(' GMT','') %>
                <% if (inc.resolved_at && inc.duration_seconds) { %> · Downtime: <%= fmtDuration(inc.duration_seconds) %><% } %>
                <% if (inc.cause) { %> · <%= inc.cause %><% } %>
              </div>
              <% if (inc.postmortem_text) { %><div class="postmortem"><%= inc.postmortem_text %></div><% } %>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>

    <section class="card reveal">
      <div class="subscribe-section">
        <div class="subscribe-title">Get Status Updates</div>
        <div class="subscribe-sub"><%= subscriberCount %> subscriber<%= subscriberCount !== 1 ? 's' : '' %></div>
        <form action="/status/page/<%= page.slug %>/subscribe" method="POST" class="subscribe-form">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <input type="email" name="email" placeholder="you@company.com" required>
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </section>

    <% if (!page.hide_powered_by) { %>
      <div class="footer">Powered by <a href="<%= process.env.BASE_URL || '/' %>">MetaWatch</a></div>
    <% } %>
  </div>
</body>
</html>
