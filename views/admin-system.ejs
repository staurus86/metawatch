<div class="page-header">
  <h1 class="page-title">Admin — System Metrics</h1>
  <div style="display:flex;gap:8px">
    <a href="/admin/queues" class="btn btn-secondary">Queue Dashboard</a>
    <a href="/admin/users" class="btn btn-ghost">← Users</a>
  </div>
</div>

<div class="stats-row" style="margin-bottom:16px">
  <div class="stat-card">
    <div class="stat-value"><%= system.users %></div>
    <div class="stat-label">Users</div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= system.urlsActive %> / <%= system.urlsTotal %></div>
    <div class="stat-label">Active URLs</div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= system.monitorsActive %> / <%= system.monitorsTotal %></div>
    <div class="stat-label">Active Monitors</div>
  </div>
  <div class="stat-card">
    <div class="stat-value"><%= system.dbSize %></div>
    <div class="stat-label">DB Size</div>
  </div>
</div>

<div class="card" style="margin-bottom:16px">
  <div class="card-header">
    <h2 class="card-title">Runtime</h2>
  </div>
  <div style="padding:14px 20px;font-size:13px;line-height:1.7;color:var(--text-muted)">
    <div><strong style="color:var(--text)">Version:</strong> <%= system.appVersion %></div>
    <div><strong style="color:var(--text)">Uptime:</strong> <%= system.uptimeSeconds %>s</div>
    <div><strong style="color:var(--text)">Last check ran at:</strong> <%= system.lastCheckRanAt ? new Date(system.lastCheckRanAt).toISOString() : 'n/a' %></div>
    <div><strong style="color:var(--text)">Snapshot generated:</strong> <%= system.generatedAt %></div>
    <div><strong style="color:var(--text)">Collection time:</strong> <%= system.collectMs %>ms</div>
  </div>
</div>

<div class="card" style="margin-bottom:16px">
  <div class="card-header">
    <h2 class="card-title">Scheduler</h2>
  </div>
  <div style="padding:14px 20px;font-size:14px;line-height:1.6">
    <div><strong>Started:</strong> <%= system.scheduler.started ? 'yes' : 'no' %></div>
    <div><strong>Leader lock held:</strong> <%= system.scheduler.hasLock ? 'yes' : 'no' %></div>
    <div><strong>Queue backend:</strong> <%= system.scheduler.queueBackend %></div>
    <div><strong>Queue mode enabled:</strong> <%= system.workerStatus && system.workerStatus.queueEnabled ? 'yes' : 'no' %></div>
    <div><strong>Queue workers enabled:</strong> <%= system.workerStatus && system.workerStatus.enabled ? 'yes' : 'no' %></div>
    <div><strong>Async notifications:</strong> <%= system.scheduler.asyncNotifications ? 'enabled' : 'disabled' %></div>
    <div><strong>Workers started:</strong> <%= system.workerStatus && system.workerStatus.started ? 'yes' : 'no' %></div>
    <div><strong>Meta worker:</strong> <%= system.workerStatus && system.workerStatus.meta ? 'up' : 'off' %></div>
    <div><strong>Uptime worker:</strong> <%= system.workerStatus && system.workerStatus.uptime ? 'up' : 'off' %></div>
    <div><strong>Notification worker:</strong> <%= system.workerStatus && system.workerStatus.notification ? 'up' : 'off' %></div>
    <div><strong>URL jobs in memory:</strong> <%= system.scheduler.urlJobs %></div>
    <div><strong>Uptime jobs in memory:</strong> <%= system.scheduler.uptimeJobs %></div>
    <div><strong>Running URL checks:</strong> <%= system.scheduler.runningUrlChecks %></div>
    <div><strong>Running uptime checks:</strong> <%= system.scheduler.runningUptimeChecks %></div>
    <div><strong>Pending URL checks:</strong> <%= system.pendingChecks %></div>
  </div>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>Interval bucket (min)</th>
          <th>URLs scheduled</th>
          <th>Earliest next run</th>
        </tr>
      </thead>
      <tbody>
        <% if (!system.schedulerBuckets || system.schedulerBuckets.length === 0) { %>
          <tr><td colspan="3" style="color:var(--text-muted)">No active URL buckets.</td></tr>
        <% } else { %>
          <% system.schedulerBuckets.forEach(function(b) { %>
            <tr>
              <td><%= b.interval_min %></td>
              <td><%= b.urls_scheduled %></td>
              <td><%= b.next_run_at ? new Date(b.next_run_at).toISOString() : 'n/a' %></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="card" style="margin-bottom:16px">
  <div class="card-header">
    <h2 class="card-title">Events & Queue</h2>
  </div>
  <% if (system.queueStats) { %>
    <div style="padding:14px 20px;font-size:13px;color:var(--text-muted);display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px">
      <div><strong style="color:var(--text)">Meta queue:</strong> waiting <%= system.queueStats.meta?.waiting || 0 %>, active <%= system.queueStats.meta?.active || 0 %>, failed <%= system.queueStats.meta?.failed || 0 %></div>
      <div><strong style="color:var(--text)">Uptime queue:</strong> waiting <%= system.queueStats.uptime?.waiting || 0 %>, active <%= system.queueStats.uptime?.active || 0 %>, failed <%= system.queueStats.uptime?.failed || 0 %></div>
      <div><strong style="color:var(--text)">Notification queue:</strong> waiting <%= system.queueStats.notification?.waiting || 0 %>, active <%= system.queueStats.notification?.active || 0 %>, failed <%= system.queueStats.notification?.failed || 0 %></div>
    </div>
  <% } %>
  <div class="table-wrapper">
    <table class="data-table">
      <tbody>
        <tr><th>Snapshots total</th><td><%= system.snapshotsTotal %></td></tr>
        <tr><th>Snapshots (24h)</th><td><%= system.snapshots24h %></td></tr>
        <tr><th>Alerts total</th><td><%= system.alertsTotal %></td></tr>
        <tr><th>Alerts (24h)</th><td><%= system.alerts24h %></td></tr>
        <tr><th>Critical alerts (24h)</th><td><%= system.alertsCritical24h %></td></tr>
        <tr><th>Notifications total</th><td><%= system.notificationsTotal %></td></tr>
        <tr><th>Notification failures (24h)</th><td><%= system.notificationsFailed24h %></td></tr>
        <tr><th>Webhook queue pending</th><td><%= system.webhookPending %></td></tr>
        <tr><th>Webhook queue failed</th><td><%= system.webhookFailed %></td></tr>
      </tbody>
    </table>
  </div>
</div>

<div class="card" style="margin-bottom:16px">
  <div class="card-header">
    <h2 class="card-title">DB Table Sizes</h2>
  </div>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr><th>Table</th><th>Size</th></tr>
      </thead>
      <tbody>
        <% if (!system.tableSizes || system.tableSizes.length === 0) { %>
          <tr><td colspan="2" style="color:var(--text-muted)">No data.</td></tr>
        <% } else { %>
          <% system.tableSizes.forEach(function(t) { %>
            <tr>
              <td><code><%= t.table_name %></code></td>
              <td><%= t.size_pretty %></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2 class="card-title">Recent Slow Queries (&gt;= <%= system.slowQueryThreshold %>ms)</h2>
  </div>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr><th>When</th><th>Duration</th><th>SQL (trimmed)</th></tr>
      </thead>
      <tbody>
        <% if (!system.slowQueries || system.slowQueries.length === 0) { %>
          <tr><td colspan="3" style="color:var(--text-muted)">No slow queries captured in this process yet.</td></tr>
        <% } else { %>
          <% system.slowQueries.forEach(function(q) { %>
            <tr>
              <td style="font-size:12px"><%= q.at %></td>
              <td><%= q.ms %>ms</td>
              <td><code style="font-size:11px"><%= q.sql %></code></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
