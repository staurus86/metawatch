<!DOCTYPE html>
<html lang="<%= lang || 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= monitor.name %> — <%= t('status.title_suffix') %></title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); }
    .status-page { max-width: 940px; margin: 0 auto; padding: 40px 20px 56px; }
    .status-header { text-align: center; margin-bottom: 24px; }
    .status-name { font-size: 30px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
    .status-url { font-size: 13px; color: var(--text-muted); word-break: break-all; }
    .status-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 16px; margin-bottom: 16px; }
    .status-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; box-shadow: var(--shadow); overflow: hidden; }
    .status-card-title { font-size: 12px; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); padding: 12px 14px; border-bottom: 1px solid var(--border); }
    .status-big { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 26px 16px; min-height: 214px; }
    .status-big--up { background: #f0fff4; }
    .status-big--down { background: #fff5f5; }
    .status-big--degraded { background: #fffaf0; }
    .status-big--pending { background: var(--bg-secondary); }
    .status-big-label { font-size: 34px; font-weight: 900; margin-top: 8px; }
    .status-big--up .status-big-label { color: #276749; }
    .status-big--down .status-big-label { color: #9b2c2c; }
    .status-big--degraded .status-big-label { color: #7b341e; }
    .status-big-sub { font-size: 13px; color: var(--text-muted); margin-top: 8px; text-align: center; }
    .metric-list { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; padding: 14px; }
    .metric { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; }
    .metric-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: .05em; }
    .metric-value { margin-top: 5px; font-size: 20px; font-weight: 800; color: var(--text); }
    .metric-value--ok { color: #276749; }
    .metric-value--warn { color: #7b341e; }
    .metric-value--error { color: #9b2c2c; }
    .simple-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; padding: 14px; }
    .simple-cell { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 8px; padding: 10px; text-align: center; }
    .simple-cell b { display: block; font-size: 18px; margin-top: 4px; }
    .status-section { margin-top: 16px; }
    .uptime-bars { display: flex; gap: 3px; height: 34px; align-items: flex-end; padding: 14px; }
    .uptime-bar { flex: 1; border-radius: 2px; min-height: 4px; cursor: default; }
    .uptime-bar--up { background: #68d391; }
    .uptime-bar--down { background: #fc8181; }
    .uptime-bar--degraded { background: #f6ad55; }
    .uptime-bar--empty { background: var(--border); }
    .bar-legend { display: flex; justify-content: space-between; font-size: 11px; color: var(--text-muted); padding: 0 14px 14px; }
    .incident-row { display: flex; justify-content: space-between; gap: 12px; padding: 12px 14px; border-top: 1px solid var(--border); font-size: 13px; }
    .incident-row:first-child { border-top: none; }
    .incident-badge { display: inline-flex; align-items: center; padding: 2px 7px; border-radius: 999px; font-size: 11px; font-weight: 700; }
    .incident-badge--resolved { background: #f0fff4; color: #276749; border: 1px solid #9ae6b4; }
    .incident-badge--open { background: #fff5f5; color: #9b2c2c; border: 1px solid #fed7d7; }
    .checks-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .checks-table th { text-align: left; padding: 9px 10px; font-size: 10px; letter-spacing: .05em; color: var(--text-muted); text-transform: uppercase; background: var(--bg-secondary); border-bottom: 1px solid var(--border); }
    .checks-table td { padding: 9px 10px; border-bottom: 1px solid var(--border); }
    .checks-table tr:last-child td { border-bottom: none; }
    .powered-by { text-align: center; margin-top: 30px; font-size: 12px; color: var(--text-muted); }
    .powered-by a { color: inherit; text-decoration: none; }
    .powered-by a:hover { text-decoration: underline; }
    @media (max-width: 800px) {
      .status-grid { grid-template-columns: 1fr; }
      .simple-grid { grid-template-columns: repeat(2, 1fr); }
      .metric-list { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="status-page">
    <div class="status-header">
      <div class="status-name"><%= monitor.name %></div>
      <div class="status-url"><%= monitor.url %></div>
    </div>

    <% const st = latestCheck ? latestCheck.status : 'pending'; %>
    <div class="status-grid">
      <div class="status-card">
        <div class="status-card-title"><%= t('status.current_status') %></div>
        <div class="status-big status-big--<%= st %>">
          <% if (st === 'up') { %><div style="font-size:52px">✅</div>
          <% } else if (st === 'down') { %><div style="font-size:52px">🔴</div>
          <% } else if (st === 'degraded') { %><div style="font-size:52px">🟡</div>
          <% } else { %><div style="font-size:52px">⏳</div>
          <% } %>
          <div class="status-big-label"><%= st.toUpperCase() %></div>
          <% if (openIncident) { %>
            <div class="status-big-sub"><%= t('status.incident_ongoing_since', { time: new Date(openIncident.started_at).toUTCString() }) %></div>
          <% } else if (latestCheck) { %>
            <div class="status-big-sub">
              <%= t('status.last_checked_at', { time: new Date(latestCheck.checked_at).toUTCString() }) %>
              <% if (latestCheck.response_time_ms != null) { %>· <%= latestCheck.response_time_ms %>ms<% } %>
              <% if (latestCheck.status_code != null) { %>· HTTP <%= latestCheck.status_code %><% } %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="status-card">
        <div class="status-card-title"><%= t('status.uptime') %></div>
        <div class="metric-list">
          <% ['24h', '7d', '30d'].forEach(function(period) { const v = uptimeWindows && uptimeWindows[period]; %>
            <div class="metric">
              <div class="metric-label"><%= period %></div>
              <div class="metric-value <%= v == null ? '' : v >= 99 ? 'metric-value--ok' : v >= 95 ? 'metric-value--warn' : 'metric-value--error' %>">
                <%= v == null ? '—' : v + '%' %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="status-card status-section">
      <div class="status-card-title"><%= t('status.performance_incidents') %></div>
      <div class="simple-grid">
        <div class="simple-cell"><%= t('status.avg_rt') %><b><%= responseStats?.avg_ms != null ? responseStats.avg_ms + 'ms' : '—' %></b></div>
        <div class="simple-cell"><%= t('status.min_rt') %><b><%= responseStats?.min_ms != null ? responseStats.min_ms + 'ms' : '—' %></b></div>
        <div class="simple-cell"><%= t('status.max_rt') %><b><%= responseStats?.max_ms != null ? responseStats.max_ms + 'ms' : '—' %></b></div>
        <div class="simple-cell"><%= t('status.incidents_30d') %><b><%= incidentSummary?.incidents_30d || 0 %></b></div>
        <div class="simple-cell"><%= t('status.check_interval') %><b><%= monitor.interval_minutes %>m</b></div>
        <div class="simple-cell"><%= t('status.threshold') %><b><%= monitor.threshold_ms %>ms</b></div>
      </div>
      <div style="padding:0 14px 14px;font-size:12px;color:var(--text-muted)">
        <%= t('status.downtime_30d') %>:
        <strong><%= incidentSummary?.downtime_seconds_30d ? fmtDuration(incidentSummary.downtime_seconds_30d) : '0s' %></strong>
      </div>
      <% if (latestCheck && latestCheck.error_message) { %>
        <div style="padding:0 14px 14px;font-size:12px;color:var(--text-muted)">
          <%= t('status.last_error') %>:
          <strong style="color:#c53030"><%= latestCheck.error_message.substring(0, 140) %></strong>
        </div>
      <% } %>
    </div>

    <div class="status-card status-section">
      <div class="status-card-title"><%= t('status.last_90_days') %></div>
      <div class="uptime-bars">
        <% dayBuckets.forEach(function(bucket) { %>
          <div class="uptime-bar uptime-bar--<%= bucket.status %>"
               style="height:<%= Math.max(4, Math.min(34, bucket.count * 4)) %>px"
               title="<%= bucket.date %>: <%= bucket.status %>"></div>
        <% }) %>
      </div>
      <div class="bar-legend">
        <span>90 days ago</span>
        <span>Today</span>
      </div>
    </div>

    <div class="status-card status-section">
      <div class="status-card-title"><%= t('status.recent_checks') %></div>
      <% if (!recentChecks || recentChecks.length === 0) { %>
        <div style="padding:16px;color:var(--text-muted);font-size:13px"><%= t('status.no_checks') %></div>
      <% } else { %>
        <div style="overflow-x:auto">
          <table class="checks-table">
            <thead>
                <tr>
                  <th><%= t('status.time_utc') %></th>
                  <th><%= t('dashboard.status') %></th>
                  <th>HTTP</th>
                  <th><%= t('status.response') %></th>
                  <th>Error</th>
                </tr>
            </thead>
            <tbody>
              <% recentChecks.forEach(function(chk) { %>
                <tr>
                  <td><%= new Date(chk.checked_at).toUTCString().replace(' GMT','') %></td>
                  <td><span class="incident-badge incident-badge--<%= chk.status === 'up' ? 'resolved' : 'open' %>"><%= chk.status.toUpperCase() %></span></td>
                  <td><%= chk.status_code != null ? chk.status_code : '—' %></td>
                  <td><%= chk.response_time_ms != null ? chk.response_time_ms + 'ms' : '—' %></td>
                  <td style="color:var(--text-muted)"><%= chk.error_message ? chk.error_message.substring(0, 90) : '' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="status-card status-section">
      <div class="status-card-title"><%= t('status.recent_incidents') %></div>
      <% if (incidents.length === 0) { %>
        <div style="padding:16px;color:var(--text-muted);font-size:13px"><%= t('status.no_incidents') %></div>
      <% } else { %>
        <% incidents.forEach(function(inc) { %>
          <div class="incident-row">
            <div>
              <div style="font-weight:600"><%= inc.cause || 'Outage' %></div>
              <div style="font-size:12px;color:var(--text-muted);margin-top:3px">
                <%= new Date(inc.started_at).toUTCString().replace(' GMT','') %>
                <% if (inc.duration_seconds) { %> · <%= t('status.duration') %>: <%= fmtDuration(inc.duration_seconds) %><% } %>
              </div>
            </div>
            <span class="incident-badge incident-badge--<%= inc.resolved_at ? 'resolved' : 'open' %>">
              <%= inc.resolved_at ? t('status.incident_resolved') : t('status.incident_ongoing') %>
            </span>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div class="powered-by">Powered by <a href="/" target="_blank">MetaWatch</a></div>
  </div>
</body>
</html>
