<div class="page-header">
  <h1 class="page-title">Bulk URL Import</h1>
  <a href="/" class="btn btn-ghost">← Dashboard</a>
</div>

<% if (error) { %>
  <div class="alert-banner alert-banner--error" style="margin-bottom:16px"><%= error %></div>
<% } %>

<% const projectsList = Array.isArray(projects) ? projects : []; %>
<% const selectedProject = projectsList.find(p => String(p.id) === String(selectedProjectId || '')); %>

<% if (preview) { %>
  <!-- Preview mode -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-header">
      <h2 class="card-title">Import Preview</h2>
    </div>
    <div style="padding:20px">
      <div class="stats-row" style="margin-bottom:20px">
        <div class="stat-card">
          <div class="stat-value"><%= preview.all %></div>
          <div class="stat-label">Total Found</div>
        </div>
        <div class="stat-card">
          <div class="stat-value"><%= preview.uniqueCount %></div>
          <div class="stat-label">Unique URLs</div>
        </div>
        <div class="stat-card stat-card--ok">
          <div class="stat-value"><%= preview.importableCount %></div>
          <div class="stat-label">Will Import</div>
        </div>
        <div class="stat-card">
          <div class="stat-value"><%= preview.existingCount %></div>
          <div class="stat-label">Already Monitored</div>
        </div>
        <% if (preview.overLimitCount > 0) { %>
          <div class="stat-card stat-card--changed">
            <div class="stat-value"><%= preview.overLimitCount %></div>
            <div class="stat-label">Over 500 Limit</div>
          </div>
        <% } %>
      </div>

      <% if (preview.overLimitCount > 0) { %>
        <div class="alert-banner alert-banner--info" style="margin-bottom:12px">
          Max import per session is <strong>500 URLs</strong>. URLs above this limit are shown but not selected.
        </div>
      <% } %>

      <% if (preview.rows.length > 0) { %>
        <form action="/urls/bulk" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <input type="hidden" name="source" value="<%= preview.source %>">
          <input type="hidden" name="urls_text" value="<%= preview.urls_text || '' %>">
          <input type="hidden" name="sitemap_url" value="<%= preview.sitemap_url || '' %>">
          <input type="hidden" name="project_id" value="<%= preview.project_id || selectedProjectId || '' %>">
          <input type="hidden" name="preview_importable_json" value="<%= JSON.stringify(preview.importableUrls) %>">
          <input type="hidden" name="confirm" value="1">

          <% if (selectedProject) { %>
            <div class="alert-banner alert-banner--info" style="margin-bottom:12px">
              URLs will be added to project: <strong><%= selectedProject.name %></strong>
            </div>
          <% } %>

          <div class="table-wrapper" style="margin-bottom:14px;max-height:360px;overflow:auto;border:1px solid var(--border);border-radius:8px">
            <table class="data-table">
              <thead>
                <tr>
                  <th style="width:38px;text-align:center">
                    <input type="checkbox" id="bulk-select-all" checked>
                  </th>
                  <th>URL</th>
                  <th style="width:130px">Priority</th>
                  <th style="width:160px">Already Monitored?</th>
                  <th style="width:140px">Will Import?</th>
                </tr>
              </thead>
              <tbody>
                <% preview.rows.forEach(function(row) { %>
                  <% const canImport = !row.isExisting && !row.overLimit; %>
                  <tr style="<%= row.isExisting ? 'opacity:.6' : '' %>">
                    <td style="text-align:center">
                      <input type="checkbox"
                             class="bulk-select-row"
                             name="selected_urls"
                             value="<%= row.url %>"
                             <%= row.willImport ? 'checked' : '' %>
                             <%= canImport ? '' : 'disabled' %>>
                    </td>
                    <td style="word-break:break-all;font-size:12px"><%= row.url %></td>
                    <td style="font-size:12px">
                      <% if (row.priority == null) { %>
                        <span class="text-muted">—</span>
                      <% } else { %>
                        <%= row.priority %>
                      <% } %>
                    </td>
                    <td>
                      <% if (row.isExisting) { %>
                        <span class="badge badge--paused">Yes</span>
                      <% } else { %>
                        <span class="badge badge--ok">No</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (row.willImport) { %>
                        <span class="badge badge--ok">Yes</span>
                      <% } else if (row.overLimit) { %>
                        <span class="badge badge--changed">Limit</span>
                      <% } else { %>
                        <span class="badge badge--paused">No</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (preview.rowsTruncated > 0) { %>
            <p class="form-hint" style="margin-bottom:12px">Preview truncated: <%= preview.rowsTruncated %> more URLs not shown.</p>
          <% } %>

          <div class="form-group" style="margin-bottom:12px;max-width:260px">
            <label class="form-label">Check Interval</label>
            <select name="check_interval_minutes" class="form-select">
              <option value="15">Every 15 minutes</option>
              <option value="60" selected>Every hour</option>
              <option value="360">Every 6 hours</option>
              <option value="1440">Every 24 hours</option>
            </select>
          </div>

          <div style="display:flex;gap:10px">
            <button id="bulk-import-submit" type="submit" class="btn btn-primary">
              Import <span id="bulk-import-count"><%= preview.importableCount %></span> URLs
            </button>
            <a href="/urls/bulk" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      <% } else { %>
        <p class="text-muted" style="margin-bottom:10px">No URLs available for import.</p>
        <a href="/urls/bulk" class="btn btn-ghost">Back</a>
      <% } %>
    </div>
  </div>

<% } else { %>
  <!-- Input form -->
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;align-items:start">

    <!-- Textarea -->
    <div class="card">
      <div class="card-header"><h2 class="card-title">Paste URLs</h2></div>
      <form action="/urls/bulk" method="POST" class="form" style="padding:16px">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="source" value="text">
        <div class="form-group">
          <label class="form-label">Project</label>
          <select name="project_id" class="form-select">
            <option value="">No project</option>
            <% projectsList.forEach(function(project) { %>
              <option value="<%= project.id %>" <%= String(selectedProjectId || '') === String(project.id) ? 'selected' : '' %>><%= project.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">One URL per line</label>
          <textarea name="urls_text" class="form-input" rows="10"
                    placeholder="https://example.com&#10;https://example.com/page&#10;https://another.com"
                    style="font-family:monospace;font-size:12px;resize:vertical"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Preview</button>
      </form>
    </div>

    <!-- File upload -->
    <div class="card">
      <div class="card-header"><h2 class="card-title">Upload CSV / XLSX</h2></div>
      <form action="/urls/bulk" method="POST" enctype="multipart/form-data" class="form" style="padding:16px">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="source" value="file">
        <div class="form-group">
          <label class="form-label">Project</label>
          <select name="project_id" class="form-select">
            <option value="">No project</option>
            <% projectsList.forEach(function(project) { %>
              <option value="<%= project.id %>" <%= String(selectedProjectId || '') === String(project.id) ? 'selected' : '' %>><%= project.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">File (CSV or XLSX)</label>
          <input type="file" name="file" class="form-input" accept=".csv,.xlsx,.xls" required>
        </div>
        <div class="form-group">
          <label class="form-label">URL Column Index (0 = first)</label>
          <input type="number" name="column" class="form-input" value="0" min="0">
        </div>
        <button type="submit" class="btn btn-primary">Preview</button>
      </form>
    </div>

    <!-- Sitemap -->
    <div class="card">
      <div class="card-header"><h2 class="card-title">Sitemap URL</h2></div>
      <form action="/urls/bulk" method="POST" class="form" style="padding:16px">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="source" value="sitemap">
        <div class="form-group">
          <label class="form-label">Project</label>
          <select name="project_id" class="form-select">
            <option value="">No project</option>
            <% projectsList.forEach(function(project) { %>
              <option value="<%= project.id %>" <%= String(selectedProjectId || '') === String(project.id) ? 'selected' : '' %>><%= project.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Sitemap URL</label>
          <input type="url" name="sitemap_url" class="form-input"
                 placeholder="https://example.com/sitemap.xml" required>
          <p class="form-hint">Supports sitemap index (nested sitemaps)</p>
        </div>
        <button type="submit" class="btn btn-primary">Fetch & Preview</button>
      </form>
    </div>

  </div>
<% } %>

<% if (locals.upgradePrompt) { %>
  <div class="upgrade-modal-backdrop">
    <div class="upgrade-modal">
      <h3><%= upgradePrompt.title || 'Upgrade your plan' %></h3>
      <p><%= upgradePrompt.message %></p>
      <div style="display:flex;gap:8px;margin-top:14px;flex-wrap:wrap">
        <a href="/billing" class="btn btn-primary">View plans</a>
        <a href="/dashboard" class="btn btn-ghost">Back to dashboard</a>
      </div>
    </div>
  </div>
<% } %>
