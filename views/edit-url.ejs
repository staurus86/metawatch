<div class="page-header">
  <h1 class="page-title">Edit URL</h1>
  <a href="/urls/<%= urlRecord.id %>" class="btn btn-ghost">← Back</a>
</div>

<div class="card" style="max-width:740px">
  <% if (locals.cloned) { %>
    <div class="alert-banner alert-banner--ok">URL cloned successfully. Update the URL below and save.</div>
  <% } %>
  <% if (error) { %>
    <div class="alert-banner alert-banner--error"><%= error %></div>
  <% } %>

  <div style="padding:12px 20px;background:var(--bg-secondary);border-bottom:1px solid var(--border);font-size:13px;color:var(--text-muted)">
    <strong>URL:</strong> <%= urlRecord.url %>
  </div>

  <form action="/urls/<%= urlRecord.id %>/edit" method="POST" class="form">

    <!-- Basic settings -->
    <div class="form-section-title">Monitoring Settings</div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="email">Alert Email</label>
        <input type="email" id="email" name="email" class="form-input"
               placeholder="you@example.com"
               value="<%= urlRecord.email || '' %>">
        <p class="form-hint">Leave blank to disable email alerts</p>
      </div>
      <div class="form-group">
        <label class="form-label" for="check_interval_minutes">Check Interval</label>
        <select id="check_interval_minutes" name="check_interval_minutes" class="form-select">
          <option value="15"  <%= urlRecord.check_interval_minutes == 15   ? 'selected' : '' %>>Every 15 minutes</option>
          <option value="60"  <%= urlRecord.check_interval_minutes == 60   ? 'selected' : '' %>>Every hour</option>
          <option value="360" <%= urlRecord.check_interval_minutes == 360  ? 'selected' : '' %>>Every 6 hours</option>
          <option value="1440"<%= urlRecord.check_interval_minutes == 1440 ? 'selected' : '' %>>Every 24 hours</option>
        </select>
      </div>
    </div>

    <!-- Monitored fields -->
    <div class="form-section-title">Fields to Monitor</div>

    <div class="checkbox-grid">
      <% const fields = [
        { name: 'monitor_title',       label: 'Title' },
        { name: 'monitor_description', label: 'Meta Description' },
        { name: 'monitor_h1',          label: 'H1 Tag' },
        { name: 'monitor_body',        label: 'Page Content' },
        { name: 'monitor_status_code', label: 'Response Code' },
        { name: 'monitor_noindex',     label: 'noindex Flag' },
        { name: 'monitor_redirect',    label: 'Redirect URL' },
        { name: 'monitor_canonical',   label: 'Canonical' },
        { name: 'monitor_robots',      label: 'robots.txt' },
        { name: 'monitor_hreflang',    label: 'hreflang' },
        { name: 'monitor_og',          label: 'OG Tags' },
        { name: 'monitor_ssl',         label: 'SSL Certificate' }
      ]; %>
      <% fields.forEach(function(f) { %>
        <label class="checkbox-label">
          <input type="checkbox" name="<%= f.name %>" value="1"
            <%= urlRecord[f.name] ? 'checked' : '' %>>
          <span><%= f.label %></span>
        </label>
      <% }) %>
    </div>

    <!-- Custom text -->
    <div class="form-group" style="margin-top:16px">
      <label class="form-label" for="custom_text">Custom Text Search</label>
      <input type="text" id="custom_text" name="custom_text" class="form-input"
             placeholder='e.g. "In Stock" or "©2025"'
             value="<%= urlRecord.custom_text || '' %>">
      <p class="form-hint">Alert when this exact text appears or disappears from the page</p>
    </div>

    <!-- Tags + Notes -->
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="tags">Tags</label>
        <input type="text" id="tags" name="tags" class="form-input"
               placeholder="seo, landing, shop"
               value="<%= urlRecord.tags || '' %>">
        <p class="form-hint">Comma-separated, for dashboard filtering</p>
      </div>
      <div class="form-group">
        <label class="form-label" for="notes">Notes</label>
        <input type="text" id="notes" name="notes" class="form-input"
               placeholder="Internal note…"
               value="<%= urlRecord.notes || '' %>">
        <p class="form-hint">For your reference only</p>
      </div>
    </div>

    <!-- Maintenance Window -->
    <div class="form-section-title">Maintenance Window</div>
    <div class="form-group">
      <label class="form-label" for="silenced_until">Silence alerts until</label>
      <input type="datetime-local" id="silenced_until" name="silenced_until" class="form-input"
             value="<%= urlRecord.silenced_until ? new Date(urlRecord.silenced_until).toISOString().slice(0,16) : '' %>">
      <p class="form-hint">Checks will continue but no notifications will be sent until this time</p>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="maintenance_cron">Recurring maintenance cron (UTC)</label>
        <input type="text" id="maintenance_cron" name="maintenance_cron" class="form-input"
               placeholder="0 2 * * 0"
               value="<%= urlRecord.maintenance_cron || '' %>">
        <p class="form-hint">Example: <code>0 2 * * 0</code> = every Sunday 02:00 UTC</p>
      </div>
      <div class="form-group">
        <label class="form-label" for="maintenance_duration_minutes">Duration (minutes)</label>
        <input type="number" id="maintenance_duration_minutes" name="maintenance_duration_minutes"
               class="form-input" min="1" max="1440" placeholder="120"
               value="<%= urlRecord.maintenance_duration_minutes || '' %>">
      </div>
    </div>

    <!-- Advanced options -->
    <details class="form-details" <%= (urlRecord.user_agent || urlRecord.ignore_numbers || urlRecord.telegram_chat_id || urlRecord.webhook_url) ? 'open' : '' %>>
      <summary class="form-section-title" style="cursor:pointer">Advanced Options ▾</summary>

      <div style="padding-top:12px">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="user_agent">Custom User-Agent</label>
            <input type="text" id="user_agent" name="user_agent" class="form-input"
                   placeholder="Mozilla/5.0 …"
                   value="<%= urlRecord.user_agent || '' %>">
            <p class="form-hint">Leave blank to use the default MetaWatch bot</p>
          </div>
          <div class="form-group">
            <label class="checkbox-label" style="margin-top:28px">
              <input type="checkbox" name="ignore_numbers" value="1"
                <%= urlRecord.ignore_numbers ? 'checked' : '' %>>
              <span>Ignore Number Changes</span>
            </label>
            <p class="form-hint" style="margin-top:4px">Skip changes where only digits differ</p>
          </div>
        </div>

        <div class="form-section-title" style="margin-top:8px">Telegram Alerts</div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="telegram_bot_token">Bot Token</label>
            <input type="text" id="telegram_bot_token" name="telegram_bot_token" class="form-input"
                   placeholder="123456:ABC-DEF… (leave blank to use global)"
                   value="<%= urlRecord.telegram_bot_token || '' %>">
          </div>
          <div class="form-group">
            <label class="form-label" for="telegram_chat_id">Chat ID</label>
            <input type="text" id="telegram_chat_id" name="telegram_chat_id" class="form-input"
                   placeholder="-100123456789"
                   value="<%= urlRecord.telegram_chat_id || '' %>">
          </div>
        </div>

        <div class="form-section-title" style="margin-top:8px">Webhook</div>
        <div class="form-group">
          <label class="form-label" for="webhook_url">Webhook URL</label>
          <input type="url" id="webhook_url" name="webhook_url" class="form-input"
                 placeholder="https://your-service.com/hook"
                 value="<%= urlRecord.webhook_url || '' %>">
          <p class="form-hint">Receives a JSON POST on each change</p>
        </div>
      </div>
    </details>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/urls/<%= urlRecord.id %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>
