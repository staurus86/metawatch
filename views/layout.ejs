<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — MetaWatch' : 'MetaWatch' %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>
  <script>
    // Apply saved theme before render to avoid flash
    (function() {
      const t = localStorage.getItem('mw-theme') || 'light';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <div class="app-layout">
    <aside class="sidebar">
      <a href="/" class="sidebar-logo">
        <span class="logo-icon">👁</span>
        <span class="logo-text">MetaWatch</span>
      </a>
      <nav class="sidebar-nav">
        <a href="/" class="nav-link <%= typeof title !== 'undefined' && title === 'Dashboard' ? 'active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/uptime" class="nav-link <%= typeof title !== 'undefined' && (title === 'Uptime' || title === 'Add Monitor') ? 'active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Uptime
        </a>
        <a href="/?tab=problems" class="nav-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Problems
        </a>
        <a href="/urls/add" class="nav-link nav-link--add">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
          Add URL
        </a>
        <a href="/urls/bulk" class="nav-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Bulk Import
        </a>
        <a href="/export/report.xlsx" class="nav-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          Export XLSX
        </a>
        <a href="/export/alerts.csv" class="nav-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
          Alerts CSV
        </a>
        <a href="/notifications" class="nav-link <%= typeof title !== 'undefined' && title === 'Notification History' ? 'active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
          Notifications
        </a>
        <a href="/tags" class="nav-link <%= typeof title !== 'undefined' && title === 'Tags' ? 'active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Tags
        </a>
        <a href="/status-pages" class="nav-link <%= typeof title !== 'undefined' && title === 'Status Pages' ? 'active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Status Pages
        </a>
        <a href="/competitors" class="nav-link <%= typeof title !== 'undefined' && title === 'Competitor Monitoring' ? 'active' : '' %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Competitors
        </a>
        <% if (locals.user && locals.user.role === 'admin') { %>
        <a href="/admin/users" class="nav-link nav-link--admin">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          Admin
        </a>
        <% } %>
      </nav>
      <div class="sidebar-footer">
        <% if (locals.user) { %>
          <div class="user-info">
            <div class="user-email"><%= locals.user.email %></div>
            <div class="user-role-badge"><%= locals.user.role %></div>
          </div>
          <a href="/profile" class="footer-link">Profile & API Key</a>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:8px">
            <form action="/logout" method="POST">
              <button type="submit" class="logout-btn">Sign Out</button>
            </form>
            <button id="dark-mode-toggle" class="dark-mode-btn" title="Toggle dark mode">
              <span id="theme-icon">🌙</span>
            </button>
          </div>
        <% } else { %>
          <a href="/api/health" target="_blank" class="health-link">API Health</a>
        <% } %>
      </div>
    </aside>
    <main class="main-content">
      <%- body %>
    </main>
  </div>

  <!-- Onboarding Modal (shown once to new users) -->
  <% if (locals.user && !locals.user.onboarding_completed) { %>
  <div id="onboarding-modal" class="onboarding-overlay">
    <div class="onboarding-box">
      <div class="onboarding-steps">
        <!-- Step 1 -->
        <div class="onboarding-step" id="ob-step-1">
          <div class="onboarding-icon">👁</div>
          <h2 class="onboarding-title">Welcome to MetaWatch!</h2>
          <p class="onboarding-desc">MetaWatch monitors your website's metadata, uptime, and content changes — and notifies you the moment something changes.</p>
          <button type="button" class="btn btn-primary" data-ob-next="2">Next →</button>
        </div>
        <!-- Step 2 -->
        <div class="onboarding-step" id="ob-step-2" style="display:none">
          <div class="onboarding-icon">🔗</div>
          <h2 class="onboarding-title">Add your first URL</h2>
          <p class="onboarding-desc">Go to <strong>Add URL</strong> to start monitoring a page. Choose which fields to track: title, meta description, H1, canonical, and more.</p>
          <div style="display:flex;gap:10px;justify-content:center;margin-top:4px">
            <button type="button" class="btn btn-ghost" data-ob-next="1">← Back</button>
            <button type="button" class="btn btn-primary" data-ob-next="3">Next →</button>
          </div>
        </div>
        <!-- Step 3 -->
        <div class="onboarding-step" id="ob-step-3" style="display:none">
          <div class="onboarding-icon">🔔</div>
          <h2 class="onboarding-title">Set up alerts</h2>
          <p class="onboarding-desc">Configure email, Telegram, or webhook notifications per URL. You can also set maintenance windows to silence alerts temporarily.</p>
          <div style="display:flex;gap:10px;justify-content:center;margin-top:4px">
            <button type="button" class="btn btn-ghost" data-ob-next="2">← Back</button>
            <button type="button" class="btn btn-primary" data-ob-finish="1">Get Started ✓</button>
          </div>
        </div>
      </div>
      <div class="onboarding-dots">
        <span class="ob-dot ob-dot--active" id="ob-dot-1"></span>
        <span class="ob-dot" id="ob-dot-2"></span>
        <span class="ob-dot" id="ob-dot-3"></span>
      </div>
      <button type="button" class="onboarding-skip" data-ob-finish="1">Skip</button>
    </div>
  </div>
  <% } %>

  <!-- Scan-all progress modal -->
  <div id="scan-modal" class="scan-modal" style="display:none">
    <div class="scan-modal-inner">
      <div class="scan-modal-title">Scanning all URLs...</div>
      <div class="scan-progress-bar-wrap">
        <div id="scan-progress-bar" class="scan-progress-bar" style="width:0%"></div>
      </div>
      <div id="scan-status-text" class="scan-status-text">Initializing...</div>
      <div id="scan-log" class="scan-log"></div>
    </div>
  </div>

  <script src="/app.js"></script>
</body>
</html>
