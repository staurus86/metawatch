<div class="page-header">
  <h1 class="page-title">My Profile</h1>
</div>

<% if (locals.message) { %>
  <div class="alert-banner alert-banner--info" style="margin-bottom:16px"><%= message %></div>
<% } %>
<% if (locals.error) { %>
  <div class="alert-banner alert-banner--error" style="margin-bottom:16px"><%= error %></div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:860px">

  <!-- Account info -->
  <div class="card">
    <div class="card-header"><h2 class="card-title">Account Info</h2></div>
    <div style="padding:20px">
      <div class="info-card" style="margin-bottom:12px">
        <div class="info-label">Email</div>
        <div class="info-value"><%= locals.user.email %></div>
      </div>
      <div class="info-card" style="margin-bottom:12px">
        <div class="info-label">Role</div>
        <div class="info-value">
          <span class="badge badge--<%= locals.user.role === 'admin' ? 'changed' : 'pending' %>">
            <%= locals.user.role %>
          </span>
        </div>
      </div>
      <div class="info-card">
        <div class="info-label">Member Since</div>
        <div class="info-value"><%= new Date(locals.user.created_at).toISOString().split('T')[0] %></div>
      </div>
    </div>
  </div>

  <!-- API Key -->
  <div class="card">
    <div class="card-header"><h2 class="card-title">API Key</h2></div>
    <div style="padding:20px">
      <p class="text-muted" style="font-size:13px;margin-bottom:12px">
        Use this key with the <code>X-API-Key</code> header to access the REST API.
      </p>
      <div class="api-key-box">
        <code id="api-key-val"><%= locals.user.api_key || 'Not generated' %></code>
        <button type="button"
                data-copy-text="<%= locals.user.api_key %>"
                data-copy-success="Copied!"
                class="btn btn-ghost" style="font-size:11px;padding:3px 8px;margin-left:8px">
          Copy
        </button>
      </div>
      <form action="/profile/regenerate-key" method="POST" style="margin-top:12px"
            data-confirm="Regenerate API key? The old key will stop working immediately.">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" class="btn btn-ghost">Regenerate Key</button>
      </form>

      <hr style="margin:20px 0;border:none;border-top:1px solid var(--border)">
      <p class="text-muted" style="font-size:13px;margin-bottom:8px">
        <strong>API Endpoints:</strong>
      </p>
      <ul style="font-size:12px;color:var(--text-muted);padding-left:20px;line-height:1.8">
        <li><code>GET /api/tasks</code> — list all monitored URLs</li>
        <li><code>GET /api/tasks/:id/results</code> — latest snapshot</li>
      </ul>
    </div>
  </div>

  <!-- Notification Defaults + Display -->
  <div class="card" style="grid-column:1/-1;max-width:860px">
    <div class="card-header"><h2 class="card-title">Preferences</h2></div>
    <form action="/profile/preferences" method="POST" class="form" style="padding:20px">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="form-section-title" style="margin-top:0">Notification Defaults</div>
      <p class="text-muted" style="font-size:13px;margin-bottom:12px">
        These values auto-fill the Add URL form (you can override per URL).
      </p>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Default alert email</label>
          <input type="email" name="default_alert_email" class="form-input"
                 placeholder="<%= locals.user.email %>"
                 value="<%= locals.user.default_alert_email || '' %>">
        </div>
        <div class="form-group">
          <label class="form-label">Default webhook URL</label>
          <input type="url" name="default_webhook_url" class="form-input"
                 placeholder="https://hooks.example.com/..."
                 value="<%= locals.user.default_webhook_url || '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Default Telegram bot token</label>
          <input type="text" name="default_telegram_token" class="form-input"
                 value="<%= locals.user.default_telegram_token || '' %>">
        </div>
        <div class="form-group">
          <label class="form-label">Default Telegram chat ID</label>
          <input type="text" name="default_telegram_chat_id" class="form-input"
                 value="<%= locals.user.default_telegram_chat_id || '' %>">
        </div>
      </div>

      <div class="form-section-title">Display Preferences</div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Default dashboard view</label>
          <select name="pref_dashboard_view" class="form-select">
            <option value="list" <%= locals.user.pref_dashboard_view === 'list' ? 'selected' : '' %>>List</option>
            <option value="projects" <%= (locals.user.pref_dashboard_view === 'projects' || locals.user.pref_dashboard_view === 'grouped') ? 'selected' : '' %>>Projects</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Time zone</label>
          <input type="text" name="pref_timezone" class="form-input"
                 placeholder="UTC"
                 value="<%= locals.user.pref_timezone || 'UTC' %>">
          <p class="form-hint">Example: UTC, Europe/Berlin, America/New_York</p>
        </div>
        <div class="form-group">
          <label class="form-label">Rows per page</label>
          <select name="pref_rows_per_page" class="form-select">
            <option value="10" <%= Number(locals.user.pref_rows_per_page) === 10 ? 'selected' : '' %>>10</option>
            <option value="25" <%= Number(locals.user.pref_rows_per_page || 25) === 25 ? 'selected' : '' %>>25</option>
            <option value="50" <%= Number(locals.user.pref_rows_per_page) === 50 ? 'selected' : '' %>>50</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label"><%= t('profile.language') %></label>
          <select name="language" class="form-select">
            <option value="en" <%= (locals.user.language || 'en') === 'en' ? 'selected' : '' %>>English</option>
            <option value="ru" <%= locals.user.language === 'ru' ? 'selected' : '' %>>Русский</option>
          </select>
          <p class="form-hint"><%= t('profile.language_hint') %></p>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Preferences</button>
      </div>
    </form>
  </div>

  <!-- Email Digest -->
  <div class="card" style="grid-column:1/-1;max-width:620px">
    <div class="card-header">
      <h2 class="card-title">Email Digest</h2>
      <% if (digestSettings && digestSettings.enabled) { %>
        <span class="badge badge--ok">Active</span>
      <% } %>
    </div>
    <form action="/profile/digest" method="POST" class="form" style="padding:20px">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <p class="text-muted" style="font-size:13px;margin-bottom:16px">
        Receive a summary covering meta changes, uptime incidents, and upcoming SSL expirations.
      </p>
      <div class="form-group">
        <label class="checkbox-label" style="margin-bottom:12px">
          <input type="checkbox" name="enabled" value="1" <%= digestSettings && digestSettings.enabled ? 'checked' : '' %>>
          <strong>Enable email digest</strong>
        </label>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Frequency</label>
          <select name="frequency" id="digest-frequency" class="form-select">
            <option value="daily" <%= !digestSettings || digestSettings.frequency === 'daily' ? 'selected' : '' %>>Daily</option>
            <option value="weekly" <%= digestSettings && digestSettings.frequency === 'weekly' ? 'selected' : '' %>>Weekly</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Send at (UTC hour)</label>
          <select name="hour" class="form-select">
            <% for (let h = 0; h < 24; h++) { %>
              <option value="<%= h %>" <%= digestSettings && digestSettings.hour === h ? 'selected' : h === 8 ? 'selected' : '' %>><%= String(h).padStart(2,'0') %>:00</option>
            <% } %>
          </select>
        </div>
        <div class="form-group" id="dow-group" style="<%= digestSettings && digestSettings.frequency === 'weekly' ? '' : 'display:none' %>">
          <label class="form-label">Day of week</label>
          <select name="day_of_week" class="form-select">
            <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function(d,i) { %>
              <option value="<%= i %>" <%= digestSettings && digestSettings.day_of_week === i ? 'selected' : i === 1 ? 'selected' : '' %>><%= d %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Delivery email</label>
        <input type="email" name="alt_email" class="form-input"
               placeholder="<%= locals.user.email %> (account email)"
               value="<%= digestSettings && digestSettings.alt_email || '' %>">
        <p class="form-hint">Leave blank to use your account email</p>
      </div>

      <div class="form-section-title" style="margin-top:6px">PDF Report Attachment</div>
      <div class="form-group">
        <label class="checkbox-label" style="margin-bottom:8px">
          <input type="checkbox" name="pdf_report_enabled" value="1" <%= digestSettings && digestSettings.pdf_report_enabled ? 'checked' : '' %> <%= reportCaps && reportCaps.scheduledPdfDigest ? '' : 'disabled' %>>
          <strong>Include PDF report in digest email</strong>
        </label>
        <p class="form-hint">Adds a generated MetaWatch PDF report as email attachment.</p>
        <% if (!(reportCaps && reportCaps.scheduledPdfDigest)) { %>
          <p class="form-hint" style="color:var(--error)">Available on Starter plan or higher. <a href="/billing">Upgrade plan</a>.</p>
        <% } %>
      </div>
      <div class="form-group" style="max-width:260px">
        <label class="form-label">PDF frequency</label>
        <select name="pdf_report_frequency" class="form-select" <%= reportCaps && reportCaps.scheduledPdfDigest ? '' : 'disabled' %>>
          <option value="weekly" <%= !digestSettings || digestSettings.pdf_report_frequency === 'weekly' ? 'selected' : '' %>>Weekly</option>
          <option value="monthly" <%= digestSettings && digestSettings.pdf_report_frequency === 'monthly' ? 'selected' : '' %>>Monthly (1st day)</option>
        </select>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Digest Settings</button>
        <button type="submit" formaction="/profile/digest/test" formmethod="POST" class="btn btn-ghost" style="font-size:13px">
          Send Test Digest
        </button>
      </div>
    </form>
  </div>

  <!-- Browser Push -->
  <div class="card" style="grid-column:1/-1;max-width:620px">
    <div class="card-header">
      <h2 class="card-title">Browser Push Alerts</h2>
      <% if (pushStats && Number(pushStats.activeCount || 0) > 0) { %>
        <span class="badge badge--ok">Active</span>
      <% } else { %>
        <span class="badge badge--paused">Inactive</span>
      <% } %>
    </div>
    <div style="padding:20px">
      <p class="text-muted" style="font-size:13px;margin-bottom:10px">
        Get instant critical alerts in this browser even if MetaWatch is not open.
      </p>
      <% if (!(pushDiagnostics && pushDiagnostics.enabled)) { %>
        <div class="alert-banner alert-banner--warning" style="margin-bottom:10px">
          Push is not configured on server. Set <code>VAPID_PUBLIC_KEY</code>, <code>VAPID_PRIVATE_KEY</code> and <code>WEB_PUSH_SUBJECT</code>.
        </div>
      <% } %>
      <div style="font-size:12px;color:var(--text-muted);margin-bottom:12px">
        Active subscriptions: <strong style="color:var(--text)"><%= pushStats ? pushStats.activeCount : 0 %></strong>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button type="button" class="btn btn-primary" id="push-enable-btn" <%= (pushDiagnostics && pushDiagnostics.enabled) ? '' : 'disabled' %>>
          Enable in this browser
        </button>
        <button type="button" class="btn btn-ghost" id="push-disable-btn" <%= (pushDiagnostics && pushDiagnostics.enabled) ? '' : 'disabled' %>>
          Disable in this browser
        </button>
        <form action="/profile/push/test" method="POST" style="display:inline">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-ghost" <%= (pushDiagnostics && pushDiagnostics.enabled) ? '' : 'disabled' %>>
            Send test push
          </button>
        </form>
      </div>
      <div id="push-status" class="form-hint" style="margin-top:10px">
        <% if (pushDiagnostics && pushDiagnostics.enabled) { %>
          Ready to subscribe.
        <% } else { %>
          Push backend unavailable.
        <% } %>
      </div>
    </div>
  </div>

  <!-- Change password -->
  <div class="card" style="grid-column:1/-1;max-width:480px">
    <div class="card-header"><h2 class="card-title">Change Password</h2></div>
    <form action="/profile/change-password" method="POST" class="form" style="padding:20px">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="form-group">
        <label class="form-label" for="current_password">Current Password</label>
        <input type="password" id="current_password" name="current_password" class="form-input" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="new_password">New Password</label>
        <input type="password" id="new_password" name="new_password" class="form-input"
               minlength="8" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="new_password2">Confirm New Password</label>
        <input type="password" id="new_password2" name="new_password2" class="form-input"
               minlength="8" required>
      </div>
      <button type="submit" class="btn btn-primary">Update Password</button>
    </form>
  </div>

  <!-- Danger Zone -->
  <div class="card" style="grid-column:1/-1;max-width:860px;border:1px solid #feb2b2">
    <div class="card-header"><h2 class="card-title" style="color:#c53030">Danger Zone</h2></div>
    <div style="padding:20px;display:flex;flex-direction:column;gap:14px">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
        <div>
          <div style="font-weight:600">Export all my data</div>
          <div class="text-muted" style="font-size:12px">Download current full XLSX report.</div>
        </div>
        <a href="/export/report.xlsx" class="btn btn-ghost" style="font-size:12px">Export</a>
      </div>

      <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
        <div>
          <div style="font-weight:600">Delete all URLs</div>
          <div class="text-muted" style="font-size:12px">Removes all monitored URLs and related history.</div>
        </div>
        <form action="/profile/delete-urls" method="POST" data-confirm="Delete all your monitored URLs? This cannot be undone.">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-danger" style="font-size:12px">Delete All URLs</button>
        </form>
      </div>

      <form action="/profile/delete-account" method="POST" data-confirm="Delete your account permanently? This cannot be undone.">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div style="font-weight:600;margin-bottom:6px">Delete account</div>
        <div class="text-muted" style="font-size:12px;margin-bottom:8px">
          Type your email (<code><%= locals.user.email %></code>) to confirm.
        </div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
          <input type="text" name="confirm_email" class="form-input" placeholder="<%= locals.user.email %>" style="max-width:320px" required>
          <button type="submit" class="btn btn-danger" style="font-size:12px">Delete Account</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function() {
    const enableBtn = document.getElementById('push-enable-btn');
    const disableBtn = document.getElementById('push-disable-btn');
    const statusEl = document.getElementById('push-status');
    if (!enableBtn || !disableBtn || !statusEl) return;

    const supportsPush = 'serviceWorker' in navigator && 'PushManager' in window && 'Notification' in window;
    if (!supportsPush) {
      statusEl.textContent = 'This browser does not support Push API.';
      enableBtn.disabled = true;
      disableBtn.disabled = true;
      return;
    }

    function setStatus(msg, isError) {
      statusEl.textContent = msg;
      statusEl.style.color = isError ? 'var(--error)' : 'var(--text-muted)';
    }

    function base64ToUint8Array(base64) {
      const padding = '='.repeat((4 - base64.length % 4) % 4);
      const base64Safe = (base64 + padding).replace(/-/g, '+').replace(/_/g, '/');
      const raw = atob(base64Safe);
      const output = new Uint8Array(raw.length);
      for (let i = 0; i < raw.length; i += 1) output[i] = raw.charCodeAt(i);
      return output;
    }

    async function fetchPublicKey() {
      const res = await fetch('/profile/push/public-key', { credentials: 'same-origin' });
      const json = await res.json().catch(() => ({}));
      if (!res.ok || !json.publicKey) {
        throw new Error(json.error || 'Push public key unavailable');
      }
      return json.publicKey;
    }

    async function registerServiceWorker() {
      return navigator.serviceWorker.register('/sw.js');
    }

    async function subscribeCurrentBrowser() {
      const permission = await Notification.requestPermission();
      if (permission !== 'granted') {
        throw new Error('Notification permission denied');
      }

      const publicKey = await fetchPublicKey();
      const reg = await registerServiceWorker();
      let sub = await reg.pushManager.getSubscription();
      if (!sub) {
        sub = await reg.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: base64ToUint8Array(publicKey)
        });
      }

      const body = JSON.stringify({ subscription: sub.toJSON() });
      const res = await fetch('/profile/push/subscribe', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok || !json.ok) throw new Error(json.error || 'Failed to save push subscription');
      setStatus('Push enabled for this browser.', false);
      return true;
    }

    async function unsubscribeCurrentBrowser() {
      const reg = await navigator.serviceWorker.getRegistration('/sw.js');
      if (!reg) {
        setStatus('No service worker registration found.', false);
        return;
      }

      const sub = await reg.pushManager.getSubscription();
      if (!sub) {
        setStatus('Push is already disabled in this browser.', false);
        return;
      }

      const endpoint = sub.endpoint;
      await sub.unsubscribe().catch(() => {});
      const res = await fetch('/profile/push/unsubscribe', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ endpoint })
      });
      const json = await res.json().catch(() => ({}));
      if (!res.ok || !json.ok) throw new Error(json.error || 'Failed to remove push subscription');
      setStatus('Push disabled for this browser.', false);
    }

    enableBtn.addEventListener('click', async () => {
      enableBtn.disabled = true;
      try {
        await subscribeCurrentBrowser();
      } catch (err) {
        setStatus(err.message || 'Failed to enable push.', true);
      } finally {
        enableBtn.disabled = false;
      }
    });

    disableBtn.addEventListener('click', async () => {
      disableBtn.disabled = true;
      try {
        await unsubscribeCurrentBrowser();
      } catch (err) {
        setStatus(err.message || 'Failed to disable push.', true);
      } finally {
        disableBtn.disabled = false;
      }
    });
  })();
</script>
