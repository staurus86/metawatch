<div class="page-header">
  <div>
    <div class="breadcrumb"><a href="/uptime">Uptime</a> / <%= monitor.name %></div>
    <h1 class="page-title"><%= monitor.name %></h1>
    <div style="font-size:13px;color:var(--text-muted);margin-top:2px"><%= monitor.url %></div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;flex-shrink:0">
    <a href="/uptime/<%= monitor.id %>/edit" class="btn btn-ghost" style="font-size:12px">✎ Edit</a>
    <button id="uptime-test-btn" class="btn btn-ghost" style="font-size:12px" data-id="<%= monitor.id %>">🔔 Test Alert</button>
    <a href="/uptime" class="btn btn-ghost" style="font-size:12px">← Back</a>
  </div>
</div>

<% if (savedMsg) { %><div class="alert-banner alert-banner--ok" style="margin-bottom:12px">Settings saved.</div><% } %>
<% if (checkedMsg) { %><div class="alert-banner alert-banner--ok" style="margin-bottom:12px">Manual check completed.</div><% } %>

<!-- Actions -->
<div class="actions-bar">
  <form action="/uptime/<%= monitor.id %>/check-now" method="POST" style="display:inline">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <button type="submit" class="btn btn-primary">▶ Check Now</button>
  </form>
  <a href="/export/uptime/<%= monitor.id %>.pdf" class="btn btn-ghost">PDF Report</a>
  <a href="/export/uptime/<%= monitor.id %>.xlsx" class="btn btn-ghost">XLSX Report</a>
  <form action="/uptime/<%= monitor.id %>/toggle" method="POST" style="display:inline">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <button type="submit" class="btn btn-ghost">
      <%= monitor.is_active ? '⏸ Pause' : '▶ Resume' %>
    </button>
  </form>
  <% if (monitor.is_public) { %>
    <a href="/status/<%= monitor.slug %>" target="_blank" class="btn btn-ghost" style="font-size:12px">↗ Public Status Page</a>
  <% } %>
  <form action="/uptime/<%= monitor.id %>/delete" method="POST" style="display:inline"
        data-confirm="Delete this monitor and all its history?">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <button type="submit" class="btn btn-danger">✕ Delete</button>
  </form>
</div>

<!-- Big status indicator -->
<% const st = latestCheck ? latestCheck.status : 'pending'; %>
<div class="uptime-status-big uptime-status-big--<%= st %>">
  <div class="uptime-status-big-dot uptime-dot-lg--<%= st %>"></div>
  <div>
    <div class="uptime-status-big-label"><%= st.toUpperCase() %></div>
    <% if (openIncident) { %>
      <div class="uptime-status-big-sub">
        Down since&nbsp;<span class="time-ago" data-ts="<%= new Date(openIncident.started_at).toISOString() %>"></span>
        (<%= openIncident.cause %>)
      </div>
    <% } else if (latestCheck) { %>
      <div class="uptime-status-big-sub">
        Last checked <span class="time-ago" data-ts="<%= new Date(latestCheck.checked_at).toISOString() %>"></span>
        <% if (latestCheck.response_time_ms != null) { %>· <%= latestCheck.response_time_ms %>ms<% } %>
      </div>
    <% } %>
  </div>
  <% if (!monitor.is_active) { %><span class="badge badge--paused" style="margin-left:12px">Paused</span><% } %>
  <% if (monitor.silenced_until && new Date(monitor.silenced_until) > new Date()) { %>
    <span class="badge badge--paused" style="margin-left:8px">Silenced until <span class="time-ago" data-ts="<%= new Date(monitor.silenced_until).toISOString() %>" data-mode="future"></span></span>
  <% } %>
</div>

<!-- Tab nav -->
<div class="tabs" style="margin-top:20px;margin-bottom:0">
  <a href="/uptime/<%= monitor.id %>?tab=overview" class="tab-link <%= activeTab === 'overview' ? 'tab-link--active' : '' %>">Overview</a>
  <a href="/uptime/<%= monitor.id %>?tab=incidents" class="tab-link <%= activeTab === 'incidents' ? 'tab-link--active' : '' %>">
    Incidents
    <% if (openIncident) { %><span class="tab-badge">1</span><% } %>
  </a>
  <a href="/uptime/<%= monitor.id %>?tab=checks" class="tab-link <%= activeTab === 'checks' ? 'tab-link--active' : '' %>">Checks Log</a>
</div>

<div class="card tab-content-card">

  <!-- OVERVIEW TAB -->
  <% if (activeTab === 'overview') { %>
    <div style="padding:20px">

      <!-- Uptime % stats -->
      <div class="section-label" style="margin-bottom:12px">Uptime Statistics</div>
      <div class="uptime-stats-row">
        <% const periods = [['1h','1 hour'],['24h','24 hours'],['7d','7 days'],['30d','30 days'],['90d','90 days']]; %>
        <% periods.forEach(function([k, label]) { %>
          <div class="uptime-stat-cell">
            <div class="uptime-stat-val <%= stats[k] == null ? '' : stats[k] >= 99 ? 'text-ok' : stats[k] >= 95 ? 'text-warn' : 'text-err' %>">
              <%= stats[k] != null ? stats[k] + '%' : '—' %>
            </div>
            <div class="uptime-stat-label"><%= label %></div>
          </div>
        <% }) %>
      </div>

      <!-- Response time stats -->
      <div class="section-label" style="margin:20px 0 12px">Response Time (last 24h)</div>
      <div class="uptime-stats-row">
        <div class="uptime-stat-cell">
          <div class="uptime-stat-val"><%= rtStats.avg_ms != null ? rtStats.avg_ms + 'ms' : '—' %></div>
          <div class="uptime-stat-label">Avg</div>
        </div>
        <div class="uptime-stat-cell">
          <div class="uptime-stat-val"><%= rtStats.min_ms != null ? rtStats.min_ms + 'ms' : '—' %></div>
          <div class="uptime-stat-label">Min</div>
        </div>
        <div class="uptime-stat-cell">
          <div class="uptime-stat-val"><%= rtStats.max_ms != null ? rtStats.max_ms + 'ms' : '—' %></div>
          <div class="uptime-stat-label">Max</div>
        </div>
        <div class="uptime-stat-cell">
          <div class="uptime-stat-val"><%= monitor.threshold_ms %>ms</div>
          <div class="uptime-stat-label">Threshold</div>
        </div>
      </div>

      <!-- Response time chart -->
      <div class="section-label" style="margin:20px 0 10px">Response Time Chart (last 24h)</div>
      <div style="height:160px">
        <canvas id="chart-uptime-rt" data-monitor-id="<%= monitor.id %>"></canvas>
      </div>

      <!-- SSL info -->
      <% if (latestCheck && latestCheck.ssl_expires_at) { %>
        <% const sslExpiry = new Date(latestCheck.ssl_expires_at); %>
        <% const sslDays = Math.ceil((sslExpiry - new Date()) / 86400000); %>
        <div class="section-label" style="margin:20px 0 10px">SSL Certificate</div>
        <div class="info-grid" style="grid-template-columns:repeat(3,1fr)">
          <div class="card info-card">
            <div class="info-label">Days Remaining</div>
            <div class="info-value">
              <span class="badge badge--<%= sslDays > 30 ? 'ok' : sslDays > 7 ? 'changed' : 'error' %>">
                <%= sslDays > 0 ? sslDays + ' days' : 'EXPIRED' %>
              </span>
            </div>
          </div>
          <div class="card info-card">
            <div class="info-label">Expires</div>
            <div class="info-value" style="font-size:13px"><%= sslExpiry.toLocaleDateString() %></div>
          </div>
          <div class="card info-card">
            <div class="info-label">Status</div>
            <div class="info-value">
              <span class="badge badge--<%= sslDays > 14 ? 'ok' : 'changed' %>">
                <%= sslDays > 14 ? 'Valid' : 'Expiring Soon' %>
              </span>
            </div>
          </div>
        </div>
      <% } %>

      <!-- Request Settings / Anti-Bot -->
      <div class="section-label" style="margin:20px 0 10px">Request Settings</div>
      <div class="info-grid" style="grid-template-columns:1fr 1fr">
        <div class="card info-card">
          <div class="info-label">Check Mode</div>
          <div class="info-value">
            <% if (monitor.browser_mode) { %>
              <span class="badge badge--ok">Browser Mode</span>
              <span style="font-size:11px;color:var(--text-muted);margin-left:4px">Real Chromium, JS challenges auto-solved</span>
            <% } else { %>
              <span class="badge">Standard (HTTP)</span>
            <% } %>
          </div>
        </div>
        <div class="card info-card">
          <div class="info-label">User-Agent</div>
          <div class="info-value" style="font-size:12px;word-break:break-all">
            <%= monitor.custom_user_agent || 'Chrome 131 / Windows (default)' %>
          </div>
        </div>
      </div>

      <%
        let cookieCount = 0;
        try {
          if (monitor.session_cookies) {
            cookieCount = JSON.parse(monitor.session_cookies).length;
          }
        } catch {}
      %>
      <div style="display:flex;align-items:center;gap:10px;margin-top:12px;flex-wrap:wrap">
        <button id="refresh-session-btn" class="btn btn-ghost" style="font-size:12px" data-id="<%= monitor.id %>">
          🔄 Auto Session
        </button>
        <button id="manual-cookies-btn" class="btn btn-ghost" style="font-size:12px">
          📋 Manual Cookies
        </button>
        <% if (cookieCount > 0) { %>
          <button id="clear-cookies-btn" class="btn btn-ghost" style="font-size:12px" data-id="<%= monitor.id %>">
            🗑 Clear Cookies
          </button>
        <% } %>
        <span class="text-muted" style="font-size:12px" id="session-cookie-info">
          <% if (cookieCount > 0) { %>
            <%= cookieCount %> cookie(s) saved
          <% } else { %>
            No saved cookies
          <% } %>
        </span>
      </div>
      <p class="form-hint" style="margin-top:6px">
        "Auto Session" — headless browser. "Manual Cookies" — вы проходите anti-bot сами и вставляете cookies.
      </p>

      <!-- Manual Cookies Modal -->
      <div id="manual-cookies-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:none;align-items:center;justify-content:center">
        <div class="card" style="max-width:620px;width:90%;max-height:90vh;overflow-y:auto;margin:auto;position:relative">
          <div style="padding:20px">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
              <h3 style="margin:0">Manual Anti-Bot Session</h3>
              <button id="manual-cookies-close" class="btn btn-ghost" style="font-size:18px;padding:2px 8px">&times;</button>
            </div>

            <div class="alert-banner alert-banner--ok" style="margin-bottom:16px;font-size:13px">
              <strong>Step 1:</strong> Open the site in your browser and pass the anti-bot check (CAPTCHA, waiting page, etc.)
            </div>
            <a href="<%= monitor.url %>" target="_blank" class="btn btn-primary" style="font-size:13px;margin-bottom:16px;display:inline-block">
              ↗ Open <%= new URL(monitor.url).hostname %> in new tab
            </a>

            <div class="alert-banner" style="margin-bottom:12px;font-size:13px;background:var(--bg-secondary);border:1px solid var(--border)">
              <strong>Step 2:</strong> After the page loads, press <kbd style="background:var(--bg);border:1px solid var(--border);border-radius:3px;padding:1px 5px;font-size:11px">F12</kbd> → Console → paste this command and press Enter:
            </div>
            <div style="position:relative;margin-bottom:16px">
              <pre id="cookie-snippet" style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;padding:10px 12px;font-size:11px;overflow-x:auto;margin:0;cursor:pointer;white-space:pre-wrap;word-break:break-all"
                   title="Click to copy">JSON.stringify({c:document.cookie,u:navigator.userAgent})</pre>
              <button id="copy-snippet-btn" class="btn btn-ghost" style="position:absolute;top:4px;right:4px;font-size:11px;padding:2px 8px">Copy</button>
            </div>

            <div class="alert-banner" style="margin-bottom:12px;font-size:13px;background:var(--bg-secondary);border:1px solid var(--border)">
              <strong>Step 3:</strong> Copy the result (starts with <code>{"c":"...</code>) and paste here:
            </div>
            <textarea id="manual-cookies-input" class="form-input" rows="4"
                      placeholder='{"c":"cf_clearance=abc123; ...", "u":"Mozilla/5.0 ..."}'
                      style="font-size:12px;font-family:monospace;margin-bottom:4px"></textarea>
            <p class="form-hint" style="margin-top:0;margin-bottom:12px">
              Also accepts plain cookies: <code>name=value; name2=value2</code>
            </p>

            <div style="display:flex;gap:8px;align-items:center">
              <button id="manual-cookies-save" class="btn btn-primary" style="font-size:13px" data-id="<%= monitor.id %>">
                Save Cookies + User-Agent
              </button>
              <span id="manual-cookies-status" style="font-size:12px;color:var(--text-muted)"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

  <!-- INCIDENTS TAB -->
  <% } else if (activeTab === 'incidents') { %>
    <% if (incidents.length === 0) { %>
      <div class="empty-state" style="padding:32px">
        <div class="empty-icon">✅</div>
        <p>No incidents recorded.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Started</th>
              <th>Resolved</th>
              <th>Duration</th>
              <th>Cause</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% incidents.forEach(function(inc) { %>
              <tr>
                <td class="nowrap">
                  <span class="time-ago" data-ts="<%= new Date(inc.started_at).toISOString() %>"></span><br>
                  <small class="text-muted"><%= new Date(inc.started_at).toUTCString().replace(' GMT','') %></small>
                </td>
                <td class="nowrap">
                  <% if (inc.resolved_at) { %>
                    <span class="time-ago" data-ts="<%= new Date(inc.resolved_at).toISOString() %>"></span>
                  <% } else { %>
                    <span class="badge badge--error">Ongoing</span>
                  <% } %>
                </td>
                <td><%= inc.resolved_at ? fmtDuration(inc.duration_seconds) : '—' %></td>
                <td><code style="font-size:11px"><%= inc.cause || '—' %></code></td>
                <td>
                  <span class="badge badge--<%= inc.resolved_at ? 'ok' : 'error' %>">
                    <%= inc.resolved_at ? 'Resolved' : 'Open' %>
                  </span>
                </td>
              </tr>
              <tr>
                <td colspan="5" style="padding:0 14px 10px;background:var(--bg-secondary)">
                  <% if (inc.postmortem_text) { %>
                    <div style="font-size:11px;font-weight:600;color:var(--text-muted);margin-bottom:3px">Post-mortem:</div>
                    <div style="font-size:13px;white-space:pre-wrap;margin-bottom:6px"><%= inc.postmortem_text %></div>
                  <% } %>
                  <details>
                    <summary style="font-size:12px;cursor:pointer;color:var(--accent)">
                      <%= inc.postmortem_text ? '✎ Edit post-mortem' : '+ Add post-mortem' %>
                    </summary>
                    <form action="/uptime/<%= monitor.id %>/incidents/<%= inc.id %>/postmortem" method="POST" style="margin-top:8px">
                      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                      <textarea name="postmortem_text" class="form-input" rows="3" style="font-size:13px;margin-bottom:6px"
                        placeholder="What caused this? How was it fixed?"><%= inc.postmortem_text || '' %></textarea>
                      <button type="submit" class="btn btn-primary" style="font-size:12px;padding:5px 12px">Save</button>
                    </form>
                  </details>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (totalIncidentPages > 1) { %>
      <div class="pagination">
        <% if (incidentPage > 1) { %><a href="/uptime/<%= monitor.id %>?tab=incidents&ipage=<%= incidentPage - 1 %>" class="btn btn-ghost btn-sm">← Prev</a><% } %>
        <span class="pagination-info">Page <%= incidentPage %> of <%= totalIncidentPages %></span>
        <% if (incidentPage < totalIncidentPages) { %><a href="/uptime/<%= monitor.id %>?tab=incidents&ipage=<%= incidentPage + 1 %>" class="btn btn-ghost btn-sm">Next →</a><% } %>
      </div>
      <% } %>
    <% } %>

  <!-- CHECKS LOG TAB -->
  <% } else if (activeTab === 'checks') { %>
    <% if (checks.length === 0) { %>
      <div class="empty-state" style="padding:32px"><p class="text-muted">No checks yet.</p></div>
    <% } else { %>
      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr><th>Time</th><th>Status</th><th>HTTP</th><th>Response (ms)</th><th>Error</th></tr>
          </thead>
          <tbody>
            <% checks.forEach(function(c) { %>
              <tr class="<%= c.status === 'down' ? 'row-error' : c.status === 'degraded' ? 'row-warn' : '' %>">
                <td class="nowrap">
                  <span class="time-ago" data-ts="<%= new Date(c.checked_at).toISOString() %>"></span><br>
                  <small class="text-muted"><%= new Date(c.checked_at).toUTCString().replace(' GMT','') %></small>
                </td>
                <td>
                  <span class="badge badge--<%= c.status === 'up' ? 'ok' : c.status === 'degraded' ? 'changed' : 'error' %>">
                    <%= c.status.toUpperCase() %>
                  </span>
                </td>
                <td><%= c.status_code || '—' %></td>
                <td><%= c.response_time_ms != null ? c.response_time_ms : '—' %></td>
                <td style="font-size:11px;color:var(--text-muted)"><%= c.error_message ? c.error_message.substring(0,80) : '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  <% } %>
</div>
