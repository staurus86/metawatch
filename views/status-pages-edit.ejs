<div class="page-header">
  <div>
    <div class="breadcrumb"><a href="/status-pages">Status Pages</a> / Edit</div>
    <h1 class="page-title"><%= page.title %></h1>
  </div>
  <% if (page.is_public) { %>
    <a href="/status/page/<%= page.slug %>" target="_blank" class="btn btn-ghost" style="font-size:12px">↗ View Public Page</a>
  <% } %>
</div>

<% if (error) { %>
  <div class="alert-banner alert-banner--error" style="margin-bottom:12px"><%= error %></div>
<% } %>

<div class="card" style="max-width:760px">
  <form action="/status-pages/<%= page.id %>/edit" method="POST" class="form">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <div class="form-group">
      <label class="form-label">Title</label>
      <input type="text" name="title" class="form-input" value="<%= page.title %>" required>
    </div>

    <div class="form-group">
      <label class="form-label">Description</label>
      <input type="text" name="description" class="form-input" value="<%= page.description || '' %>">
    </div>

    <div class="form-group">
      <label class="form-label">Include Monitors</label>
      <div class="checkbox-grid">
        <% monitors.forEach(function(m) { %>
          <label class="checkbox-label">
            <input type="checkbox" name="monitor_ids" value="<%= m.id %>"
                   <%= page.monitor_ids && page.monitor_ids.includes(m.id) ? 'checked' : '' %>>
            <%= m.name || m.url %>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="is_public" value="on" <%= page.is_public ? 'checked' : '' %>> Public page
      </label>
    </div>

    <div class="form-group" style="padding:14px;border:1px solid var(--border);border-radius:8px;background:var(--bg-secondary)">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap">
        <div style="font-weight:600">Branding (Agency plan)</div>
        <% if (!isAgencyPlan) { %>
          <a href="/billing?upgrade=Agency" class="btn btn-ghost" style="font-size:11px;padding:3px 8px">Upgrade to Agency</a>
        <% } %>
      </div>
      <div style="font-size:12px;color:var(--text-muted);margin-top:6px">
        Point CNAME <code>status.yourcompany.com</code> to <code><%= (process.env.BASE_URL || '').replace(/^https?:\/\//, '') %></code>
      </div>

      <div style="margin-top:12px;display:grid;grid-template-columns:1fr 1fr;gap:10px">
        <div>
          <label class="form-label">Custom domain</label>
          <input
            type="text"
            name="custom_domain"
            class="form-input"
            placeholder="status.company.com"
            value="<%= page.custom_domain || '' %>"
            <%= isAgencyPlan ? '' : 'disabled' %>>
        </div>
        <div>
          <label class="form-label">Primary color</label>
          <input
            type="text"
            name="primary_color"
            class="form-input"
            placeholder="#4299e1"
            value="<%= page.primary_color || '#4299e1' %>"
            <%= isAgencyPlan ? '' : 'disabled' %>>
        </div>
      </div>

      <div style="margin-top:10px">
        <label class="form-label">Logo URL or base64 data URL</label>
        <input
          type="text"
          name="logo_url"
          class="form-input"
          placeholder="https://cdn.example.com/logo.png"
          value="<%= page.logo_url || '' %>"
          <%= isAgencyPlan ? '' : 'disabled' %>>
      </div>

      <div class="form-group" style="margin-top:10px;margin-bottom:0">
        <label class="checkbox-label">
          <input type="checkbox" name="hide_powered_by" value="on" <%= page.hide_powered_by ? 'checked' : '' %> <%= isAgencyPlan ? '' : 'disabled' %>>
          Hide “Powered by MetaWatch”
        </label>
      </div>
    </div>

    <div style="margin-top:8px;padding:12px;background:var(--bg-secondary);border-radius:6px;font-size:12px">
      <strong>Public URL:</strong>
      <code><%= process.env.BASE_URL || '' %>/status/page/<%= page.slug %></code>
      <% if (page.custom_domain) { %>
        <div style="margin-top:4px"><strong>Custom domain:</strong> <code>https://<%= page.custom_domain %></code></div>
      <% } %>
    </div>

    <div class="form-actions" style="margin-top:16px">
      <button type="submit" class="btn btn-primary">Save</button>
      <a href="/status-pages" class="btn btn-ghost">Cancel</a>
    </div>
  </form>

  <div style="padding:0 18px 18px">
    <form action="/status-pages/<%= page.id %>/delete" method="POST" style="display:inline"
          data-confirm="Delete this status page?">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="btn btn-danger">Delete</button>
    </form>
  </div>
</div>
