<div class="page-header">
  <h1 class="page-title">Dashboard</h1>
  <div style="display:flex;gap:8px;align-items:center">
    <button id="scan-all-btn" class="btn btn-ghost">⟳ Scan All</button>
    <a href="/urls/add" class="btn btn-primary">+ Add URL</a>
  </div>
</div>

<% if (importedCount != null) { %>
  <div class="alert-banner alert-banner--ok" style="margin-bottom:16px">
    ✓ Imported <%= importedCount %> URL<%= importedCount !== 1 ? 's' : '' %>
    <% if (importSkipped != null) { %>
      and skipped <%= importSkipped %>.
    <% } else { %>
      successfully.
    <% } %>
    First checks are running in the background.
    <% if (importTag) { %>
      <a href="/?tab=all&tag=<%= encodeURIComponent(importTag) %>" style="margin-left:8px">View imported URLs →</a>
    <% } %>
  </div>
<% } %>

<!-- Uptime summary (if any monitors) -->
<% if (locals.uptimeSummary && uptimeSummary.total > 0) { %>
<div class="uptime-summary-bar" style="margin-bottom:16px">
  <span style="font-size:13px;font-weight:600;color:var(--text)">Uptime Monitors:</span>
  <span class="badge badge--ok" style="margin-left:8px"><%= uptimeSummary.up %> UP</span>
  <% if (uptimeSummary.degraded > 0) { %><span class="badge badge--changed" style="margin-left:4px"><%= uptimeSummary.degraded %> DEGRADED</span><% } %>
  <% if (uptimeSummary.down > 0) { %><span class="badge badge--error" style="margin-left:4px"><%= uptimeSummary.down %> DOWN</span><% } %>
  <a href="/uptime" style="font-size:12px;color:var(--accent);margin-left:12px;text-decoration:none">View all →</a>
</div>
<% } %>

<!-- Stats row -->
<div class="stats-row">
  <div class="stat-card">
    <div id="stat-total" class="stat-value"><%= stats.total %></div>
    <div class="stat-label">Total URLs</div>
  </div>
  <div class="stat-card stat-card--ok">
    <div id="stat-ok" class="stat-value"><%= stats.ok %></div>
    <div class="stat-label">OK</div>
  </div>
  <div class="stat-card stat-card--changed">
    <div id="stat-changed" class="stat-value"><%= stats.changed %></div>
    <div class="stat-label">Changed</div>
  </div>
  <div class="stat-card stat-card--error">
    <div id="stat-error" class="stat-value"><%= stats.error %></div>
    <div class="stat-label">Error</div>
  </div>
</div>

<!-- Charts row -->
<div class="charts-row">
  <div class="card chart-card">
    <div class="card-header"><h3 class="card-title">Response Codes</h3></div>
    <div class="chart-donut-wrap">
      <canvas id="chart-status"></canvas>
    </div>
  </div>
  <div class="card chart-card">
    <div class="card-header"><h3 class="card-title">Indexability</h3></div>
    <div class="chart-donut-wrap">
      <canvas id="chart-index"></canvas>
    </div>
  </div>
  <div class="card chart-card">
    <div class="card-header"><h3 class="card-title">Change Status (24h)</h3></div>
    <div class="chart-donut-wrap">
      <canvas id="chart-changes"></canvas>
    </div>
  </div>
  <div class="card chart-card chart-card--wide">
    <div class="card-header"><h3 class="card-title">Alerts (last 30 days)</h3></div>
    <div style="padding:16px;height:180px">
      <canvas id="chart-trend"></canvas>
    </div>
  </div>
</div>

<!-- Tabs + Tag filter -->
<div style="display:flex;align-items:center;gap:0;flex-wrap:wrap">
  <div class="tabs" style="margin-bottom:0;flex:1">
    <a href="/?tab=all<%= tagFilter ? '&tag=' + encodeURIComponent(tagFilter) : '' %>&per_page=<%= perPage %>"
       class="tab-link <%= tab === 'all' ? 'tab-link--active' : '' %>">All URLs</a>
    <a href="/?tab=problems<%= tagFilter ? '&tag=' + encodeURIComponent(tagFilter) : '' %>&per_page=<%= perPage %>"
       class="tab-link <%= tab === 'problems' ? 'tab-link--active' : '' %>">
      Problems
      <% if (stats.changed + stats.error > 0) { %>
        <span class="tab-badge"><%= stats.changed + stats.error %></span>
      <% } %>
    </a>
  </div>
  <% if (allTags.length > 0) { %>
  <div style="display:flex;align-items:center;gap:6px;padding:0 8px">
    <span style="font-size:12px;color:var(--text-muted)">Tag:</span>
    <a href="/?tab=<%= tab %>&per_page=<%= perPage %>" class="tag-chip <%= !tagFilter ? 'tag-chip--active' : '' %>">All</a>
    <% allTags.forEach(function(t) { %>
      <a href="/?tab=<%= tab %>&tag=<%= encodeURIComponent(t) %>&per_page=<%= perPage %>"
         class="tag-chip <%= tagFilter === t ? 'tag-chip--active' : '' %>"><%= t %></a>
    <% }) %>
  </div>
  <% } %>
</div>

<!-- URL list -->
<div class="card" style="border-top-left-radius:0">
  <div class="card-header">
    <h2 class="card-title">
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:600">
        <input type="checkbox" id="select-all-urls" style="width:14px;height:14px">
        <% if (tab === 'problems') { %>Problem URLs<% } else { %>Monitored URLs<% } %>
      </label>
    </h2>
    <div style="display:flex;gap:8px;align-items:center">
      <input id="url-search" type="search" class="form-input" style="width:220px;padding:5px 10px;font-size:13px"
             placeholder="Filter URLs…" autocomplete="off">
      <% if (tab === 'problems' && urls.length > 0) { %>
        <form action="/urls/accept-all-changes" method="POST">
          <button type="submit" class="btn btn-ghost" style="font-size:12px;padding:4px 10px">
            ✓ Accept All Changes
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Bulk action bar (hidden until rows are selected) -->
  <div id="bulk-action-bar" style="display:none;align-items:center;gap:8px;padding:8px 16px;background:var(--bg-secondary);border-bottom:1px solid var(--border);font-size:13px">
    <span><strong id="bulk-count">0</strong> selected</span>
    <form id="bulk-form" action="/urls/bulk-action" method="POST" style="display:flex;gap:6px">
      <button type="submit" name="action" value="pause" class="btn btn-ghost" style="font-size:12px;padding:3px 10px">⏸ Pause</button>
      <button type="submit" name="action" value="resume" class="btn btn-ghost" style="font-size:12px;padding:3px 10px">▶ Resume</button>
      <button type="submit" name="action" value="accept" class="btn btn-ghost" style="font-size:12px;padding:3px 10px">✓ Accept</button>
      <button type="submit" name="action" value="delete" class="btn btn-danger" style="font-size:12px;padding:3px 10px"
              data-confirm-message="Delete selected URLs?">✕ Delete</button>
    </form>
  </div>
  <% if (urls.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon"><% if (tab === 'problems') { %>✅<% } else { %>🔍<% } %></div>
      <p><% if (tab === 'problems') { %>No problems detected!<% } else { %>No URLs monitored yet.<% } %></p>
      <% if (tab !== 'problems') { %>
        <a href="/urls/add" class="btn btn-primary">Add your first URL</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="url-list">
      <% urls.forEach(function(u) { %>
        <div class="url-row-wrap">
          <input type="checkbox" class="url-row-cb" value="<%= u.id %>" style="margin:0 4px 0 12px;flex-shrink:0">
        <a href="/urls/<%= u.id %>" class="url-row">
          <div class="url-row-left">
            <span class="status-dot status-dot--<%= u.status.toLowerCase() %>"></span>
            <div class="url-info">
              <div class="url-text"><%= u.url %></div>
              <div class="url-meta">
                <% if (u.last_checked) { %>
                  Last checked: <span class="time-ago" data-ts="<%= new Date(u.last_checked).toISOString() %>"></span>
                <% } else { %>
                  <span class="text-muted">Not checked yet</span>
                <% } %>
                &nbsp;·&nbsp; Every <%= u.check_interval_minutes >= 60 ? (u.check_interval_minutes / 60) + 'h' : u.check_interval_minutes + 'min' %>
                <% if (!u.is_active) { %>&nbsp;·&nbsp; <span class="badge badge--paused">Paused</span><% } %>
                <% if (u.tags) { u.tags.split(',').filter(Boolean).forEach(function(t) { %>
                  &nbsp;<a href="/?tab=<%= tab %>&tag=<%= encodeURIComponent(t.trim()) %>&per_page=<%= perPage %>" class="tag-chip" data-stop-row-nav="1"><%= t.trim() %></a>
                <% }) } %>
              </div>
            </div>
          </div>
          <div class="url-row-right">
            <% if (u.uptime_pct != null) { %>
              <span class="uptime-badge uptime-badge--<%= u.uptime_pct >= 99 ? 'great' : u.uptime_pct >= 95 ? 'ok' : 'warn' %>">
                <%= u.uptime_pct %>%
              </span>
            <% } %>
            <% if (u.last_status_code) { %>
              <span class="badge <%= u.last_status_code === 200 ? 'badge--ok' : 'badge--error' %>">
                <%= u.last_status_code === 0 ? 'ERR' : u.last_status_code %>
              </span>
            <% } %>
            <span class="badge badge--<%= u.status.toLowerCase() %>"><%= u.status %></span>
            <% if (u.recent_alert_count > 0) { %>
              <span class="alert-count"><%= u.recent_alert_count %> alert<%= u.recent_alert_count !== 1 ? 's' : '' %></span>
            <% } %>
          </div>
        </a>
        </div>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %>
        <a href="/?tab=<%= tab %>&page=<%= page - 1 %>&per_page=<%= perPage %>" class="btn btn-ghost btn-sm">← Prev</a>
      <% } %>
      <span class="pagination-info">Page <%= page %> of <%= totalPages %> &nbsp;·&nbsp; <%= totalCount %> URLs &nbsp;·&nbsp; <%= perPage %> / page</span>
      <% if (page < totalPages) { %>
        <a href="/?tab=<%= tab %>&page=<%= page + 1 %>&per_page=<%= perPage %>" class="btn btn-ghost btn-sm">Next →</a>
      <% } %>
    </div>
    <% } %>
  <% } %>
</div>

<!-- Recent Alerts -->
<div class="card" style="margin-top:24px">
  <div class="card-header">
    <h2 class="card-title">
      Recent Alerts
      <span class="text-muted" style="font-size:14px;font-weight:400">(last 24h)</span>
    </h2>
    <% if (alertFields.length > 0) { %>
      <div style="display:flex;align-items:center;gap:8px">
        <label style="font-size:12px;color:var(--text-muted)">Filter:</label>
        <select data-nav-base="/?tab=<%= tab %>&per_page=<%= perPage %>&field="
                class="form-select" style="padding:4px 8px;font-size:12px;width:auto">
          <option value="">All fields</option>
          <% alertFields.forEach(function(f) { %>
            <option value="<%= f %>" <%= fieldFilter === f ? 'selected' : '' %>><%= f %></option>
          <% }) %>
        </select>
      </div>
    <% } %>
  </div>
  <% if (recentAlerts.length === 0) { %>
    <div class="empty-state" style="padding:32px">
      <p class="text-muted">No alerts in the last 24 hours.</p>
    </div>
  <% } else { %>
    <div class="alerts-list">
      <% recentAlerts.forEach(function(alert) { %>
        <div class="alert-row">
          <div class="alert-row-main">
            <span class="alert-field"><%= alert.field_changed %></span>
            changed on
            <a href="/urls/<%= alert.url_id %>" class="alert-url"><%= alert.url %></a>
          </div>
          <div class="alert-row-meta">
            <span class="time-ago" data-ts="<%= new Date(alert.detected_at).toISOString() %>"></span>
          </div>
          <div class="alert-diff">
            <span class="diff-old"><%= (alert.old_value || '').substring(0, 100) %><%= (alert.old_value || '').length > 100 ? '…' : '' %></span>
            <span class="diff-arrow">→</span>
            <span class="diff-new"><%= (alert.new_value || '').substring(0, 100) %><%= (alert.new_value || '').length > 100 ? '…' : '' %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
