<%
  const paramsBase = {
    tab: tab || 'all',
    per_page: String(perPage || 25),
    view: view || 'projects'
  };
  if (q) paramsBase.q = q;
  if (statusFilter) paramsBase.status = statusFilter;
  if (sort) paramsBase.sort = sort;
  if (dir) paramsBase.dir = dir;
  if (tagFilter) paramsBase.tag = tagFilter;
  if (projectFilter) paramsBase.project = projectFilter;
  if (fieldFilter) paramsBase.field = fieldFilter;
  if (unhealthyOnly) paramsBase.unhealthy = '1';

  function queryWith(overrides) {
    const data = { ...paramsBase, ...(overrides || {}) };
    for (const key of Object.keys(data)) {
      if (data[key] === null || data[key] === undefined || data[key] === '') delete data[key];
    }
    return '/dashboard?' + new URLSearchParams(data).toString();
  }

  const fieldBaseParams = new URLSearchParams({
    tab: tab || 'all',
    per_page: String(perPage || 25),
    view: view || 'projects'
  });
  if (q) fieldBaseParams.set('q', q);
  if (statusFilter) fieldBaseParams.set('status', statusFilter);
  if (sort) fieldBaseParams.set('sort', sort);
  if (dir) fieldBaseParams.set('dir', dir);
  if (tagFilter) fieldBaseParams.set('tag', tagFilter);
  if (projectFilter) fieldBaseParams.set('project', projectFilter);
  if (unhealthyOnly) fieldBaseParams.set('unhealthy', '1');
  const fieldNavBase = '/dashboard?' + fieldBaseParams.toString() + '&field=';

  function sortLink(columnKey) {
    const nextDir = (sort === columnKey && dir === 'asc') ? 'desc' : 'asc';
    return queryWith({ sort: columnKey, dir: nextDir, page: null });
  }

  function sortArrow(columnKey) {
    if (sort !== columnKey) return '↕';
    return dir === 'asc' ? '↑' : '↓';
  }

  function healthBadgeClass(score) {
    if (score == null) return 'badge--pending';
    if (Number(score) >= 90) return 'badge--ok';
    if (Number(score) >= 70) return 'badge--changed';
    return 'badge--error';
  }

  function healthTooltip(urlRow) {
    const reasons = Array.isArray(urlRow.health_reasons) ? urlRow.health_reasons : [];
    if (reasons.length === 0) return 'No active deductions';
    return reasons.join(' • ');
  }
%>

<div class="page-header">
  <h1 class="page-title"><%= t('dashboard.title') %></h1>
  <div style="display:flex;gap:8px;align-items:center">
    <a href="/reports" class="btn btn-ghost">Reports</a>
    <a href="/export/report.pdf" class="btn btn-ghost">PDF Report</a>
    <button id="scan-all-btn" class="btn btn-ghost">⟳ <%= t('dashboard.scan_all') %></button>
    <a href="/urls/add" class="btn btn-primary">+ <%= t('dashboard.add_url') %></a>
  </div>
</div>

<% if (importedCount != null) { %>
  <div class="alert-banner alert-banner--ok" style="margin-bottom:16px">
    ✓ Imported <%= importedCount %> URL<%= importedCount !== 1 ? 's' : '' %>
    <% if (importSkipped != null) { %>
      and skipped <%= importSkipped %>.
    <% } else { %>
      successfully.
    <% } %>
    First checks are running in the background.
    <% if (importTag) { %>
      <a href="<%= queryWith({ tab: 'all', tag: importTag }) %>" style="margin-left:8px">View imported URLs →</a>
    <% } %>
  </div>
<% } %>

<!-- Uptime summary (if any monitors) -->
<% if (locals.uptimeSummary && uptimeSummary.total > 0) { %>
<div class="uptime-summary-bar" style="margin-bottom:16px">
  <span style="font-size:13px;font-weight:600;color:var(--text)">Uptime Monitors:</span>
  <span class="badge badge--ok" style="margin-left:8px"><%= uptimeSummary.up %> UP</span>
  <% if (uptimeSummary.degraded > 0) { %><span class="badge badge--changed" style="margin-left:4px"><%= uptimeSummary.degraded %> DEGRADED</span><% } %>
  <% if (uptimeSummary.down > 0) { %><span class="badge badge--error" style="margin-left:4px"><%= uptimeSummary.down %> DOWN</span><% } %>
  <a href="/uptime" style="font-size:12px;color:var(--accent);margin-left:12px;text-decoration:none">View all →</a>
</div>
<% } %>

<!-- Stats row -->
<div class="stats-row">
  <div class="stat-card">
    <div id="stat-total" class="stat-value"><%= stats.total %></div>
    <div class="stat-label"><%= t('dashboard.total_urls') %></div>
  </div>
  <div class="stat-card stat-card--ok">
    <div id="stat-ok" class="stat-value"><%= stats.ok %></div>
    <div class="stat-label"><%= t('dashboard.ok') %></div>
  </div>
  <div class="stat-card stat-card--changed">
    <div id="stat-changed" class="stat-value"><%= stats.changed %></div>
    <div class="stat-label"><%= t('dashboard.changed') %></div>
  </div>
  <div class="stat-card stat-card--error">
    <div id="stat-error" class="stat-value"><%= stats.error %></div>
    <div class="stat-label"><%= t('dashboard.error') %></div>
  </div>
  <div class="stat-card <%= stats.avgHealthScore == null ? '' : stats.avgHealthScore >= 90 ? 'stat-card--ok' : stats.avgHealthScore >= 70 ? 'stat-card--changed' : 'stat-card--error' %>">
    <div id="stat-health" class="stat-value"><%= stats.avgHealthScore == null ? '—' : stats.avgHealthScore %></div>
    <div class="stat-label"><%= t('dashboard.avg_health_score') %></div>
  </div>
</div>

<!-- Charts row -->
<div class="charts-row">
  <div class="card chart-card">
    <div class="card-header"><h3 class="card-title">Response Codes</h3></div>
    <div class="chart-donut-wrap">
      <canvas id="chart-status"></canvas>
    </div>
  </div>
  <div class="card chart-card">
    <div class="card-header"><h3 class="card-title">Indexability</h3></div>
    <div class="chart-donut-wrap">
      <canvas id="chart-index"></canvas>
    </div>
  </div>
  <div class="card chart-card">
    <div class="card-header"><h3 class="card-title">Change Status (24h)</h3></div>
    <div class="chart-donut-wrap">
      <canvas id="chart-changes"></canvas>
    </div>
  </div>
  <div class="card chart-card chart-card--wide">
    <div class="card-header"><h3 class="card-title">Alerts (last 30 days)</h3></div>
    <div style="padding:16px;height:180px">
      <canvas id="chart-trend"></canvas>
    </div>
  </div>
</div>

<!-- Tabs + view + filters -->
<div style="display:flex;align-items:center;gap:0;flex-wrap:wrap">
  <div class="tabs" style="margin-bottom:0;flex:1">
    <a href="<%= queryWith({ tab: 'all', page: null }) %>" class="tab-link <%= tab === 'all' ? 'tab-link--active' : '' %>"><%= t('dashboard.all_urls') %></a>
    <a href="<%= queryWith({ tab: 'problems', page: null }) %>" class="tab-link <%= tab === 'problems' ? 'tab-link--active' : '' %>">
      <%= t('dashboard.problems') %>
      <% if (stats.changed + stats.error > 0) { %>
        <span class="tab-badge"><%= stats.changed + stats.error %></span>
      <% } %>
    </a>
  </div>
  <div class="tabs" style="margin:0;gap:4px">
    <a href="<%= queryWith({ view: 'projects', page: null }) %>" class="tab-link <%= view === 'projects' ? 'tab-link--active' : '' %>"><%= t('dashboard.projects') %></a>
    <a href="<%= queryWith({ view: 'list', page: null }) %>" class="tab-link <%= view === 'list' ? 'tab-link--active' : '' %>"><%= t('dashboard.urls') %></a>
  </div>
</div>

<div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin:10px 0 12px">
  <% if (allTags.length > 0) { %>
    <div style="display:flex;align-items:center;gap:6px">
      <span style="font-size:12px;color:var(--text-muted)">Tag:</span>
      <a href="<%= queryWith({ tag: null, page: null }) %>" class="tag-chip <%= !tagFilter ? 'tag-chip--active' : '' %>">All</a>
      <% allTags.forEach(function(t) { %>
        <a href="<%= queryWith({ tag: t, page: null }) %>" class="tag-chip <%= tagFilter === t ? 'tag-chip--active' : '' %>"><%= t %></a>
      <% }) %>
    </div>
  <% } %>

  <% if (projectOptions && projectOptions.length > 0) { %>
    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
      <span style="font-size:12px;color:var(--text-muted)">Project:</span>
      <a href="<%= queryWith({ project: null, page: null }) %>" class="tag-chip <%= !projectFilter ? 'tag-chip--active' : '' %>">All</a>
      <% projectOptions.forEach(function(p) { %>
        <a href="<%= queryWith({ project: String(p.id), page: null }) %>" class="tag-chip <%= projectFilter === String(p.id) ? 'tag-chip--active' : '' %>"><%= p.name %></a>
      <% }) %>
      <% if (unassignedCount > 0 || projectFilter === 'none') { %>
        <a href="<%= queryWith({ project: 'none', page: null }) %>" class="tag-chip <%= projectFilter === 'none' ? 'tag-chip--active' : '' %>">Unassigned</a>
      <% } %>
    </div>
  <% } %>
</div>

<form method="GET" action="/dashboard" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin:0 0 14px">
  <input type="hidden" name="tab" value="<%= tab || 'all' %>">
  <input type="hidden" name="view" value="<%= view || 'projects' %>">
  <input type="hidden" name="per_page" value="<%= perPage || 25 %>">
  <% if (tagFilter) { %><input type="hidden" name="tag" value="<%= tagFilter %>"><% } %>
  <% if (projectFilter) { %><input type="hidden" name="project" value="<%= projectFilter %>"><% } %>
  <% if (fieldFilter) { %><input type="hidden" name="field" value="<%= fieldFilter %>"><% } %>
  <% if (sort) { %><input type="hidden" name="sort" value="<%= sort %>"><% } %>
  <% if (dir) { %><input type="hidden" name="dir" value="<%= dir %>"><% } %>

  <input
    name="q"
    type="search"
    class="form-input"
    style="width:260px;padding:6px 10px;font-size:13px"
    placeholder="<%= t('dashboard.search_placeholder') %>"
    value="<%= q || '' %>"
    autocomplete="off">

  <select name="status" class="form-select" style="padding:6px 10px;font-size:13px;width:auto">
    <option value="" <%= !statusFilter ? 'selected' : '' %>><%= t('dashboard.all_statuses') %></option>
    <option value="ok" <%= statusFilter === 'ok' ? 'selected' : '' %>><%= t('dashboard.status_ok') %></option>
    <option value="changed" <%= statusFilter === 'changed' ? 'selected' : '' %>><%= t('dashboard.status_changed') %></option>
    <option value="error" <%= statusFilter === 'error' ? 'selected' : '' %>><%= t('dashboard.status_error') %></option>
    <option value="paused" <%= statusFilter === 'paused' ? 'selected' : '' %>><%= t('dashboard.status_paused') %></option>
  </select>

  <label style="display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted)">
    <input type="checkbox" name="unhealthy" value="1" <%= unhealthyOnly ? 'checked' : '' %>>
    <%= t('dashboard.unhealthy_only') %>
  </label>

  <button type="submit" class="btn btn-ghost" style="font-size:12px;padding:6px 12px"><%= t('dashboard.apply') %></button>
  <a href="<%= queryWith({ q: null, status: null, unhealthy: null, page: null }) %>" class="btn btn-ghost" style="font-size:12px;padding:6px 12px"><%= t('dashboard.reset') %></a>
</form>

<!-- Projects view -->
<% if (view === 'projects') { %>
  <div class="card" style="border-top-left-radius:0">
    <div class="card-header">
      <h2 class="card-title"><%= t('dashboard.meta_by_project') %></h2>
      <div style="display:flex;gap:8px;align-items:center">
        <a href="/projects" class="btn btn-ghost" style="font-size:12px;padding:5px 10px"><%= t('dashboard.manage_projects') %></a>
      </div>
    </div>

    <% if (!projectGroups || projectGroups.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📁</div>
        <p>No URLs found for current filters.</p>
        <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap">
          <a href="/projects" class="btn btn-ghost">Create Project</a>
          <a href="/urls/add" class="btn btn-primary">Add URL</a>
        </div>
      </div>
    <% } else { %>
      <div style="padding:14px 16px">
        <% projectGroups.forEach(function(group) { %>
          <section class="group-section" style="margin-bottom:18px">
            <div class="group-section-header" style="margin-bottom:0;padding:10px 0">
              <div class="group-section-title"><%= group.name %></div>
              <span class="badge badge--pending"><%= group.total %> URL<%= group.total !== 1 ? 's' : '' %></span>
              <% if (group.ok > 0) { %><span class="badge badge--ok"><%= group.ok %> OK</span><% } %>
              <% if (group.changed > 0) { %><span class="badge badge--changed"><%= group.changed %> Changed</span><% } %>
              <% if (group.error > 0) { %><span class="badge badge--error"><%= group.error %> Error</span><% } %>
              <% if (group.pending > 0) { %><span class="badge badge--pending"><%= group.pending %> Pending</span><% } %>
              <span style="margin-left:auto"></span>
              <a href="/urls/add<%= group.id ? '?project_id=' + group.id : '' %>" class="btn btn-ghost" style="font-size:12px;padding:4px 10px">+ Add URL</a>
            </div>
            <div class="url-list" style="border:1px solid var(--border);border-radius:8px;overflow:hidden">
              <% group.urls.forEach(function(u) { %>
                <a href="/urls/<%= u.id %>" class="url-row project-url-row">
                  <div class="url-row-left">
                    <span class="status-dot status-dot--<%= u.status.toLowerCase() %>"></span>
                    <div class="url-info">
                      <div class="url-text">
                        <%= u.url %>
                        <% if (String(u.render_mode || 'static').toLowerCase() === 'headless') { %>
                          <span class="badge badge--changed" style="margin-left:6px;font-size:10px;vertical-align:middle">JS</span>
                        <% } %>
                      </div>
                      <div class="url-meta">
                        <% if (u.last_checked) { %>
                          Last checked: <span class="time-ago" data-ts="<%= new Date(u.last_checked).toISOString() %>"></span>
                        <% } else { %>
                          <span class="text-muted">Not checked yet</span>
                        <% } %>
                        &nbsp;·&nbsp; Every <%= u.check_interval_minutes >= 60 ? (u.check_interval_minutes / 60) + 'h' : u.check_interval_minutes + 'min' %>
                        <% if (!u.is_active) { %>&nbsp;·&nbsp; <span class="badge badge--paused">Paused</span><% } %>
                        <% if (u.tags) { u.tags.split(',').filter(Boolean).forEach(function(t) { %>
                          &nbsp;<a href="<%= queryWith({ tag: t.trim(), page: null }) %>" class="tag-chip" data-stop-row-nav="1"><%= t.trim() %></a>
                        <% }) } %>
                      </div>
                    </div>
                  </div>
                  <div class="url-row-right">
                    <span class="badge <%= healthBadgeClass(u.health_score) %>" title="<%= healthTooltip(u) %>">
                      <%= t('dashboard.health_score') %>: <%= u.health_score == null ? '—' : u.health_score %>
                    </span>
                    <% if (u.uptime_pct != null) { %>
                      <span class="uptime-badge uptime-badge--<%= u.uptime_pct >= 99 ? 'great' : u.uptime_pct >= 95 ? 'ok' : 'warn' %>"><%= u.uptime_pct %>%</span>
                    <% } %>
                    <% if (u.last_status_code || u.last_status_code === 0) { %>
                      <span class="badge <%= u.last_status_code === 200 ? 'badge--ok' : 'badge--error' %>">
                        <%= u.last_status_code === 0 ? 'ERR' : u.last_status_code %>
                      </span>
                    <% } %>
                    <span class="badge badge--<%= u.status.toLowerCase() %>"><%= u.status %></span>
                    <% if (u.recent_alert_count > 0) { %>
                      <span class="alert-count"><%= u.recent_alert_count %> alert<%= u.recent_alert_count !== 1 ? 's' : '' %></span>
                    <% } %>
                  </div>
                </a>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </div>
    <% } %>
  </div>

<!-- URL list view -->
<% } else { %>
  <div class="card" style="border-top-left-radius:0">
    <div class="card-header">
      <h2 class="card-title">
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-weight:600">
          <input type="checkbox" id="select-all-urls" style="width:14px;height:14px">
          <% if (tab === 'problems') { %>Problem URLs<% } else { %>Monitored URLs<% } %>
        </label>
      </h2>
      <div style="display:flex;gap:8px;align-items:center">
        <% if (tab === 'problems' && urls.length > 0) { %>
          <form action="/urls/accept-all-changes" method="POST">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <button type="submit" class="btn btn-ghost" style="font-size:12px;padding:4px 10px">
              ✓ Accept All Changes
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <!-- Bulk action bar (hidden until rows are selected) -->
    <div id="bulk-action-bar" style="display:none;align-items:center;gap:8px;padding:8px 16px;background:var(--bg-secondary);border-bottom:1px solid var(--border);font-size:13px">
      <span><strong id="bulk-count">0</strong> selected</span>
      <form id="bulk-form" action="/urls/bulk-action" method="POST" style="display:flex;gap:6px">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" name="action" value="pause" class="btn btn-ghost" style="font-size:12px;padding:3px 10px">⏸ Pause</button>
        <button type="submit" name="action" value="resume" class="btn btn-ghost" style="font-size:12px;padding:3px 10px">▶ Resume</button>
        <button type="submit" name="action" value="accept" class="btn btn-ghost" style="font-size:12px;padding:3px 10px">✓ Accept</button>
        <button type="submit" name="action" value="delete" class="btn btn-danger" style="font-size:12px;padding:3px 10px"
                data-confirm-message="Delete selected URLs?">✕ Delete</button>
      </form>
    </div>

    <% if (urls.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon"><% if (tab === 'problems') { %>✅<% } else { %>🔍<% } %></div>
        <p><% if (tab === 'problems') { %>No problems detected!<% } else { %>No URLs monitored yet.<% } %></p>
        <% if (tab !== 'problems') { %>
          <a href="/urls/add" class="btn btn-primary">Add your first URL</a>
        <% } %>
      </div>
    <% } else { %>
      <div style="display:flex;align-items:center;gap:14px;padding:10px 16px;border-bottom:1px solid var(--border);font-size:12px;color:var(--text-muted)">
        <a href="<%= sortLink('last_checked') %>" style="text-decoration:none;color:inherit">
          <%= t('dashboard.last_checked') %> <%= sortArrow('last_checked') %>
        </a>
        <a href="<%= sortLink('status') %>" style="text-decoration:none;color:inherit">
          <%= t('dashboard.status') %> <%= sortArrow('status') %>
        </a>
        <a href="<%= sortLink('url') %>" style="text-decoration:none;color:inherit">
          <%= t('dashboard.url') %> <%= sortArrow('url') %>
        </a>
        <a href="<%= sortLink('changes') %>" style="text-decoration:none;color:inherit">
          <%= t('dashboard.changes') %> <%= sortArrow('changes') %>
        </a>
        <a href="<%= sortLink('health_score') %>" style="text-decoration:none;color:inherit">
          <%= t('dashboard.health_score') %> <%= sortArrow('health_score') %>
        </a>
      </div>
      <div class="url-list">
        <% urls.forEach(function(u) { %>
          <div class="url-row-wrap">
            <input type="checkbox" class="url-row-cb" value="<%= u.id %>" style="margin:0 4px 0 12px;flex-shrink:0">
            <a href="/urls/<%= u.id %>" class="url-row">
              <div class="url-row-left">
                <span class="status-dot status-dot--<%= u.status.toLowerCase() %>"></span>
                <div class="url-info">
                  <div class="url-text">
                    <%= u.url %>
                    <% if (String(u.render_mode || 'static').toLowerCase() === 'headless') { %>
                      <span class="badge badge--changed" style="margin-left:6px;font-size:10px;vertical-align:middle">JS</span>
                    <% } %>
                  </div>
                  <div class="url-meta">
                    <% if (u.last_checked) { %>
                      Last checked: <span class="time-ago" data-ts="<%= new Date(u.last_checked).toISOString() %>"></span>
                    <% } else { %>
                      <span class="text-muted">Not checked yet</span>
                    <% } %>
                    &nbsp;·&nbsp; Every <%= u.check_interval_minutes >= 60 ? (u.check_interval_minutes / 60) + 'h' : u.check_interval_minutes + 'min' %>
                    <% if (u.project_name) { %>&nbsp;·&nbsp; <span class="badge badge--pending"><%= u.project_name %></span><% } %>
                    <% if (!u.is_active) { %>&nbsp;·&nbsp; <span class="badge badge--paused">Paused</span><% } %>
                    <% if (u.tags) { u.tags.split(',').filter(Boolean).forEach(function(t) { %>
                      &nbsp;<a href="<%= queryWith({ tag: t.trim(), page: null }) %>" class="tag-chip" data-stop-row-nav="1"><%= t.trim() %></a>
                    <% }) } %>
                  </div>
                </div>
              </div>
              <div class="url-row-right">
                <span class="badge <%= healthBadgeClass(u.health_score) %>" title="<%= healthTooltip(u) %>">
                  <%= t('dashboard.health_score') %>: <%= u.health_score == null ? '—' : u.health_score %>
                </span>
                <% if (u.uptime_pct != null) { %>
                  <span class="uptime-badge uptime-badge--<%= u.uptime_pct >= 99 ? 'great' : u.uptime_pct >= 95 ? 'ok' : 'warn' %>">
                    <%= u.uptime_pct %>%
                  </span>
                <% } %>
                <% if (u.last_status_code || u.last_status_code === 0) { %>
                  <span class="badge <%= u.last_status_code === 200 ? 'badge--ok' : 'badge--error' %>">
                    <%= u.last_status_code === 0 ? 'ERR' : u.last_status_code %>
                  </span>
                <% } %>
                <span class="badge badge--<%= u.status.toLowerCase() %>"><%= u.status %></span>
                <% if (u.recent_alert_count > 0) { %>
                  <span class="alert-count"><%= u.recent_alert_count %> alert<%= u.recent_alert_count !== 1 ? 's' : '' %></span>
                <% } %>
              </div>
            </a>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="<%= queryWith({ page: page - 1 }) %>" class="btn btn-ghost btn-sm">← Prev</a>
        <% } %>
        <span class="pagination-info">Page <%= page %> of <%= totalPages %> &nbsp;·&nbsp; <%= totalCount %> URLs &nbsp;·&nbsp; <%= perPage %> / page</span>
        <% if (page < totalPages) { %>
          <a href="<%= queryWith({ page: page + 1 }) %>" class="btn btn-ghost btn-sm">Next →</a>
        <% } %>
      </div>
      <% } %>
    <% } %>
  </div>
<% } %>

<!-- Recent Alerts -->
<div class="card" style="margin-top:24px">
  <div class="card-header">
    <h2 class="card-title">
      <%= t('dashboard.recent_alerts') %>
      <span class="text-muted" style="font-size:14px;font-weight:400">(<%= t('dashboard.last_24h') %>)</span>
    </h2>
    <% if (alertFields.length > 0) { %>
      <div style="display:flex;align-items:center;gap:8px">
        <label style="font-size:12px;color:var(--text-muted)">Filter:</label>
        <select data-nav-base="<%= fieldNavBase %>" class="form-select" style="padding:4px 8px;font-size:12px;width:auto">
          <option value="">All fields</option>
          <% alertFields.forEach(function(f) { %>
            <option value="<%= f %>" <%= fieldFilter === f ? 'selected' : '' %>><%= f %></option>
          <% }) %>
        </select>
      </div>
    <% } %>
  </div>
  <% if (recentAlerts.length === 0) { %>
    <div class="empty-state" style="padding:32px">
      <p class="text-muted">No alerts in the last 24 hours.</p>
    </div>
  <% } else { %>
    <div class="alerts-list">
      <% recentAlerts.forEach(function(alert) { %>
        <div class="alert-row">
          <div class="alert-row-main">
            <span class="alert-field"><%= alert.field_changed %></span>
            changed on
            <a href="/urls/<%= alert.url_id %>" class="alert-url"><%= alert.url %></a>
          </div>
          <div class="alert-row-meta">
            <span class="time-ago" data-ts="<%= new Date(alert.detected_at).toISOString() %>"></span>
          </div>
          <div class="alert-diff">
            <span class="diff-old"><%= (alert.old_value || '').substring(0, 100) %><%= (alert.old_value || '').length > 100 ? '…' : '' %></span>
            <span class="diff-arrow">→</span>
            <span class="diff-new"><%= (alert.new_value || '').substring(0, 100) %><%= (alert.new_value || '').length > 100 ? '…' : '' %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
