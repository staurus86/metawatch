# Database — Railway provides DATABASE_URL automatically
DATABASE_URL=postgresql://user:password@host:5432/database

# Email alerts (SMTP) — optional; alerts are skipped if not set
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=MetaWatch <alerts@your-domain.com>

# Application
BASE_URL=https://your-app.railway.app
PORT=3000
NODE_ENV=production
# Runtime split controls (Railway web/worker)
ENABLE_WEB=true
ENABLE_SCHEDULER=true
ENABLE_QUEUE_WORKERS=false
ENABLE_HEADLESS=false
HEADLESS_MAX_PAGES=2

# Queue / BullMQ (optional, but recommended for scale)
REDIS_URL=
BULLMQ_PREFIX=metawatch
QUEUE_META_DEDUP_MS=45000
QUEUE_UPTIME_DEDUP_MS=45000
ENABLE_ASYNC_NOTIFICATIONS=false
META_WORKER_CONCURRENCY=5
UPTIME_WORKER_CONCURRENCY=5
NOTIFICATION_WORKER_CONCURRENCY=10
WORKER_LOCK_PREFIX=metawatch:lock
META_WORKER_LOCK_TTL_MS=1200000
UPTIME_WORKER_LOCK_TTL_MS=900000

# Global Telegram bot (used when per-URL token is not set)
TELEGRAM_BOT_TOKEN=

# Retention (days, 0 = keep forever)
SNAPSHOT_RETENTION_DAYS=90
ALERT_RETENTION_DAYS=180
NOTIFICATION_LOG_RETENTION_DAYS=180
WEBHOOK_LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=90
COMPETITOR_RETENTION_DAYS=60
INCIDENT_RETENTION_DAYS=180

# SSL warning threshold (days before expiry to alert)
SSL_WARN_DAYS=30

# Auth — generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-here

# Alert noise control
ENABLE_ALERT_STATE_ENGINE=true
DEFAULT_ALERT_COOLDOWN_MINUTES=60

# Outbound request safety (SSRF protection)
ENABLE_OUTBOUND_SAFETY=true
ALLOW_PRIVATE_TARGETS=false

# Webhook signing (optional)
WEBHOOK_SIGNING_SECRET=

# Public status SLO targets (optional)
PUBLIC_SLO_TARGET_30D=99.9
PUBLIC_SLO_TARGET_7D=99.5

# DB diagnostics
SLOW_QUERY_MS=250
ADMIN_SYSTEM_CACHE_TTL_MS=30000

# API limiter
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100
API_V2_STATS_CACHE_TTL_MS=60000

# Slack OAuth integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=
SLACK_CHANNEL_CACHE_TTL_MS=60000

# Web Push notifications (optional, Phase 2)
# Generate VAPID keys once:
#   npx web-push generate-vapid-keys
WEB_PUSH_SUBJECT=mailto:alerts@your-domain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=
